<!DOCTYPE html>
<html lang="{{#if synagogue.adminLanguage}}{{synagogue.adminLanguage}}{{else}}ru{{/if}}" dir="{{#if adminDir}}{{adminDir}}{{else}}ltr{{/if}}">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <meta name="color-scheme" content="light dark">
</head>

<body class="admin-body admin-theme-{{#if synagogue.adminColorMode}}{{synagogue.adminColorMode}}{{else}}dark{{/if}}{{#if adminIsRtl}} admin-rtl{{/if}}">
    <nav class="navbar navbar-expand-lg navbar-dark admin-navbar">
        <a class="navbar-brand" href="/admin/{{synagogue.slug}}/dashboard">Synagogue Admin</a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#adminNavbar"
            aria-controls="adminNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="adminNavbar">
            <ul class="navbar-nav admin-nav-links mr-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/admin/{{synagogue.slug}}/dashboard">{{t 'settings'}}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/admin/{{synagogue.slug}}/people">{{t 'people'}}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/admin/{{synagogue.slug}}/slideshow">{{t 'slideshow'}}</a>
                </li>
            </ul>
            <div class="admin-navbar-actions">
                <a class="btn btn-outline-light btn-admin-nav-board" href="/s/{{synagogue.slug}}" target="_blank" rel="noopener">{{t 'view_board'}}</a>
                <a class="btn btn-outline-light" href="/admin/logout">{{t 'logout'}}</a>
            </div>
        </div>
    </nav>
    <div id="adminBusyOverlay" class="admin-busy-overlay" hidden aria-hidden="true">
        <div class="admin-busy-card">
            <div class="admin-busy-spinner" role="status"></div>
            <span id="adminBusyText">{{t 'saving'}}</span>
        </div>
    </div>
    <div class="admin-container">
        {{{body}}}
    </div>
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/admin-slideshow.js"></script>
    <script src="/js/admin-locale.js"></script>
</body>

</html>
