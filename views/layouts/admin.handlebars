<!DOCTYPE html>
<html lang="{{#if synagogue.adminLanguage}}{{synagogue.adminLanguage}}{{else}}ru{{/if}}" dir="{{#if adminDir}}{{adminDir}}{{else}}ltr{{/if}}">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin Dashboard</title>
    <link rel="icon" href="{{#if yahrzeitTodayCount}}{{faviconAlertUrl}}{{else}}{{faviconUrl}}{{/if}}" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <meta name="color-scheme" content="light dark">
</head>

<body class="admin-body admin-theme-{{#if synagogue.adminColorMode}}{{synagogue.adminColorMode}}{{else}}dark{{/if}}{{#if adminIsRtl}} admin-rtl{{/if}}">
    <nav class="navbar navbar-expand-lg navbar-dark admin-navbar">
        <a class="navbar-brand admin-navbar-brand" href="/admin/{{synagogue.slug}}/dashboard">
            {{#if showOfficialLogo}}
            <img class="admin-brand-logo" src="{{officialLogoUrl}}" alt="">
            {{/if}}
            <span>Synagogue Admin</span>
        </a>
        <button class="navbar-toggler admin-navbar-toggler" type="button"
            aria-controls="adminNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div id="adminNavBackdrop" class="admin-nav-backdrop" aria-hidden="true"></div>
        <div class="collapse navbar-collapse admin-nav-drawer" id="adminNavbar">
            <ul class="navbar-nav admin-nav-links mr-auto">
                {{#if adminPermissions.settings}}
                <li class="nav-item">
                    <a class="nav-link" href="/admin/{{synagogue.slug}}/dashboard">
                        <svg class="admin-nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 15.5A3.5 3.5 0 0 1 8.5 12 3.5 3.5 0 0 1 12 8.5a3.5 3.5 0 0 1 3.5 3.5 3.5 3.5 0 0 1-3.5 3.5m7.43-2.53c.04-.32.07-.64.07-.97 0-.33-.03-.66-.07-1l2.11-1.63c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.31-.61-.22l-2.49 1c-.52-.39-1.06-.73-1.69-.98l-.37-2.65A.506.506 0 0 0 14 2h-4c-.25 0-.46.18-.5.42l-.37 2.65c-.63.25-1.17.59-1.69.98l-2.49-1c-.22-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64L4.57 11c-.04.34-.07.67-.07 1 0 .33.03.65.07.97l-2.11 1.66c-.19.15-.25.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1.01c.52.4 1.06.74 1.69.99l.37 2.65c.04.24.25.42.5.42h4c.25 0 .46-.18.5-.42l.37-2.65c.63-.26 1.17-.59 1.69-.99l2.49 1.01c.22.08.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.66Z"/></svg>
                        {{t 'settings'}}
                    </a>
                </li>
                {{/if}}
                {{#if adminPermissions.people}}
                <li class="nav-item">
                    <a class="nav-link{{#if yahrzeitTodayCount}} nav-link-yahrzeit-alert{{/if}}" href="/admin/{{synagogue.slug}}/yahrzeit">
                        <svg class="admin-nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2c-1.1 0-2 .9-2 2v1.07C7.06 5.56 5 7.92 5 11v5l-2 2v1h18v-1l-2-2v-5c0-3.08-2.06-5.44-5-5.93V4c0-1.1-.9-2-2-2m0 2c.55 0 1 .45 1 1v1h-2V5c0-.55.45-1 1-1m-1 9h2v3h-2v-3Z"/></svg>
                        {{t 'yahrzeit_page'}}{{#if yahrzeitTodayCount}} <span class="nav-yahrzeit-badge">{{yahrzeitTodayCount}}</span>{{/if}}
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/admin/{{synagogue.slug}}/people">
                        <svg class="admin-nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M13.5.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8C20 8.61 17.41 3.8 13.5.67zM11.71 19c-1.78 0-3.22-1.4-3.22-3.14 0-1.62 1.05-2.76 2.81-3.12 1.77-.36 3.6-1.21 4.62-2.58.39 1.29.59 2.65.59 4.04 0 2.65-2.15 4.8-4.8 4.8z"/></svg>
                        {{t 'people'}}
                    </a>
                </li>
                {{/if}}
                {{#if adminPermissions.events}}
                <li class="nav-item">
                    <a class="nav-link" href="/admin/{{synagogue.slug}}/events">
                        <svg class="admin-nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2m0 16H5V8h14v11M7 10h5v5H7v-5Z"/></svg>
                        {{t 'community_events'}}
                    </a>
                </li>
                {{/if}}
                {{#unless adminUser}}
                <li class="nav-item">
                    <a class="nav-link" href="/admin/{{synagogue.slug}}/users">
                        <svg class="admin-nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3m-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3m0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5m8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5Z"/></svg>
                        {{t 'user_management'}}
                    </a>
                </li>
                {{/unless}}
            </ul>
            <div class="admin-navbar-actions">
                {{#if adminUser}}
                <span class="admin-user-badge">{{#if adminUser.displayName}}{{adminUser.displayName}}{{else}}{{adminUser.username}}{{/if}}</span>
                {{/if}}
                <a class="btn btn-outline-light btn-admin-nav-board" href="/s/{{synagogue.slug}}" target="_blank" rel="noopener">
                    <svg class="admin-nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M21 3H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h5v2h8v-2h5c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2m0 14H3V5h18v12Z"/></svg>
                    {{t 'view_board'}}
                </a>
                <a class="btn btn-outline-light" href="/admin/logout">
                    <svg class="admin-nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5-5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
                    {{t 'logout'}}
                </a>
            </div>
        </div>
    </nav>
    <div id="adminBusyOverlay" class="admin-busy-overlay" hidden aria-hidden="true">
        <div class="admin-busy-card">
            <div class="admin-busy-spinner" role="status"></div>
            <span id="adminBusyText">{{t 'saving'}}</span>
        </div>
    </div>
    <div class="admin-container">
        {{{body}}}
    </div>
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/admin-nav.js"></script>
    <script src="/js/contact-platform-ui.js"></script>
    <script src="/js/admin-person-card.js"></script>
    <script src="/js/admin-people.js"></script>
    <script src="/js/admin-events.js"></script>
    <script src="/js/admin-locale.js"></script>
    <script src="/js/admin-users.js"></script>
</body>

</html>
