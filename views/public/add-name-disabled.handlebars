<section class="public-card">
    <h1>{{publicT 'disabled_title'}}</h1>
    {{#if errorMessage}}
    <p class="public-error" role="alert">{{errorMessage}}</p>
    {{/if}}
    <p class="public-intro">{{publicT 'disabled_message'}}</p>
    <div class="public-actions">
        <a href="{{boardUrl}}" class="public-button public-button-secondary">{{publicT 'back_to_board'}}</a>
    </div>
</section>
