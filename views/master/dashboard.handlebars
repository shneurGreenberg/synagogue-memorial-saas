<div class="master-page">
    <header class="master-page-header">
        <div>
            <h1>Communities</h1>
            <p class="master-subtitle">Create and manage synagogues — login slug, password, and map location for Shabbat times.</p>
        </div>
    </header>

    {{#if saved}}
    <div class="master-alert master-alert-success">Saved successfully.</div>
    {{/if}}
    {{#if error}}
    <div class="master-alert master-alert-danger">
        {{#if (eq error 'slug_exists')}}That login slug is already in use.
        {{else}}{{#if (eq error 'invalid_slug')}}Slug must use lowercase letters, numbers, and hyphens (spaces are removed automatically).
        {{else}}{{#if (eq error 'missing_fields')}}Please fill in all required fields.
        {{else}}{{error}}{{/if}}{{/if}}{{/if}}
    </div>
    {{/if}}

    <section class="master-panel">
        <div class="master-panel-header">
            <h2>Add new community</h2>
        </div>
        <div class="master-panel-body">
            <form method="POST" action="/master/add" class="master-community-form" data-location-picker="add">
                <div class="master-form-grid">
                    <div class="master-field">
                        <label for="addName">Community name</label>
                        <input type="text" name="name" id="addName" class="form-control master-input master-name-input" required placeholder="Novosibirsk Synagogue">
                    </div>
                    <div class="master-field">
                        <label for="addSlug">Admin login (slug)</label>
                        <input type="text" name="slug" id="addSlug" class="form-control master-input master-slug-input" required placeholder="novosibirsk">
                        <span class="master-hint">Spaces are ignored — e.g. "novo sibirsk" becomes "novosibirsk"</span>
                    </div>
                    <div class="master-field">
                        <label for="addPassword">Admin password</label>
                        <input type="password" name="adminPassword" id="addPassword" class="form-control master-input" required minlength="4" autocomplete="new-password">
                    </div>
                </div>

                <div class="master-location-block">
                    <h3 class="master-location-title">Location</h3>
                    <p class="master-hint">Search for a city or click/drag the pin on the map. Lat, long, and timezone fill automatically.</p>
                    <div class="master-location-search-wrap">
                        <label for="addCitySearch">Search city</label>
                        <input type="search" id="addCitySearch" class="form-control master-input master-city-search" placeholder="Start typing a city name..." autocomplete="off">
                        <div class="master-city-results" hidden></div>
                    </div>
                    <input type="hidden" name="city" class="master-city-hidden" value="">
                    <input type="hidden" name="lat" class="master-lat-hidden" value="55.0226">
                    <input type="hidden" name="long" class="master-lng-hidden" value="82.9318">
                    <div class="master-coords-row">
                        <div class="master-field">
                            <label>Latitude</label>
                            <input type="text" class="form-control master-input master-lat-display" readonly>
                        </div>
                        <div class="master-field">
                            <label>Longitude</label>
                            <input type="text" class="form-control master-input master-lng-display" readonly>
                        </div>
                        <div class="master-field master-field-wide">
                            <label for="addTimezone">Timezone</label>
                            <input type="text" name="timezone" id="addTimezone" class="form-control master-input master-timezone-input" value="Asia/Novosibirsk">
                        </div>
                    </div>
                    <div class="master-map" data-default-lat="55.0226" data-default-lng="82.9318"></div>
                </div>

                <div class="master-form-actions">
                    <button type="submit" class="btn master-btn master-btn-primary">Create community</button>
                </div>
            </form>
        </div>
    </section>

    <section class="master-panel">
        <div class="master-panel-header">
            <h2>Existing communities ({{synagogues.length}})</h2>
        </div>
        <div class="master-panel-body">
            {{#if synagogues.length}}
            <div class="master-community-list">
                {{#each synagogues}}
                <article class="master-community-card" data-id="{{this._id}}">
                    <header class="master-community-card-header">
                        <div>
                            <h3>{{this.name}}</h3>
                            <p class="master-community-meta">
                                <code>{{this.slug}}</code>
                                · {{#if this.location.city}}{{this.location.city}}{{else}}No city{{/if}}
                                · {{#if this.location.timezone}}{{this.location.timezone}}{{else}}Asia/Novosibirsk{{/if}}
                            </p>
                        </div>
                        <div class="master-community-card-links">
                            <a href="/s/{{this.slug}}" class="btn master-btn master-btn-secondary btn-sm" target="_blank" rel="noopener">Board</a>
                            <a href="/admin/login" class="btn master-btn master-btn-secondary btn-sm" target="_blank" rel="noopener">Admin</a>
                            <button type="button" class="btn master-btn master-btn-secondary btn-sm master-toggle-edit" aria-expanded="false">Edit</button>
                        </div>
                    </header>
                    <div class="master-community-edit" hidden>
                        <form method="POST" action="/master/edit" class="master-community-form" data-location-picker="edit-{{this._id}}">
                            <input type="hidden" name="id" value="{{this._id}}">
                            <div class="master-form-grid">
                                <div class="master-field">
                                    <label>Community name</label>
                                    <input type="text" name="name" class="form-control master-input" value="{{this.name}}" required>
                                </div>
                                <div class="master-field">
                                    <label>Admin login (slug)</label>
                                    <input type="text" name="slug" class="form-control master-input master-slug-input" value="{{this.slug}}" required>
                                </div>
                                <div class="master-field">
                                    <label>New password (optional)</label>
                                    <input type="password" name="adminPassword" class="form-control master-input" placeholder="Leave blank to keep" autocomplete="new-password">
                                </div>
                            </div>

                            <div class="master-location-block">
                                <h3 class="master-location-title">Location</h3>
                                <div class="master-location-search-wrap">
                                    <label>Search city</label>
                                    <input type="search" class="form-control master-input master-city-search" value="{{this.location.city}}" placeholder="Search city..." autocomplete="off">
                                    <div class="master-city-results" hidden></div>
                                </div>
                                <input type="hidden" name="city" class="master-city-hidden" value="{{this.location.city}}">
                                <input type="hidden" name="lat" class="master-lat-hidden" value="{{this.location.lat}}">
                                <input type="hidden" name="long" class="master-lng-hidden" value="{{this.location.long}}">
                                <div class="master-coords-row">
                                    <div class="master-field">
                                        <label>Latitude</label>
                                        <input type="text" class="form-control master-input master-lat-display" readonly value="{{this.location.lat}}">
                                    </div>
                                    <div class="master-field">
                                        <label>Longitude</label>
                                        <input type="text" class="form-control master-input master-lng-display" readonly value="{{this.location.long}}">
                                    </div>
                                    <div class="master-field master-field-wide">
                                        <label>Timezone</label>
                                        <input type="text" name="timezone" class="form-control master-input master-timezone-input" value="{{#if this.location.timezone}}{{this.location.timezone}}{{else}}Asia/Novosibirsk{{/if}}">
                                    </div>
                                </div>
                                <div class="master-map" data-default-lat="{{this.location.lat}}" data-default-lng="{{this.location.long}}"></div>
                            </div>

                            <div class="master-edit-actions">
                                <button type="submit" class="btn master-btn master-btn-primary">Save changes</button>
                                <button type="submit" formaction="/master/delete" formmethod="POST" class="btn master-btn master-btn-danger" onclick="return confirm('Delete this community permanently?');">Delete</button>
                            </div>
                        </form>
                    </div>
                </article>
                {{/each}}
            </div>
            {{else}}
            <p class="master-empty">No communities yet. Create one above.</p>
            {{/if}}
        </div>
    </section>
</div>
