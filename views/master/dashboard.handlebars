<div class="master-page">
    <header class="master-page-header">
        <div>
            <h1>{{t 'communities_heading'}}</h1>
            <p class="master-subtitle">{{t 'communities_subtitle'}}</p>
        </div>
    </header>

    {{#if saved}}
    <div class="master-alert master-alert-success">{{t 'saved_success'}}</div>
    {{/if}}
    {{#if error}}
    <div class="master-alert master-alert-danger">
        {{#if (eq error 'slug_exists')}}{{t 'error_slug_exists'}}
        {{else}}{{#if (eq error 'invalid_slug')}}{{t 'error_invalid_slug'}}
        {{else}}{{#if (eq error 'missing_fields')}}{{t 'error_missing_fields'}}
        {{else}}{{error}}{{/if}}{{/if}}{{/if}}
    </div>
    {{/if}}

    <section class="master-panel">
        <div class="master-panel-header master-panel-header-split">
            <div>
                <h2>{{t 'add_community'}}</h2>
                <p class="master-panel-intro">{{t 'wizard_dashboard_intro'}}</p>
            </div>
            <a href="/master/new" class="btn master-btn master-btn-primary">
                <svg class="master-btn-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                {{t 'wizard_start'}}
            </a>
        </div>
    </section>

    <section class="master-panel">
        <div class="master-panel-header">
            <h2>{{t 'existing_communities'}} ({{synagogues.length}})</h2>
        </div>
        <div class="master-panel-body">
            {{#if synagogues.length}}
            <div class="master-community-list">
                {{#each synagogues}}
                <article class="master-community-card" data-id="{{this._id}}">
                    <header class="master-community-card-header">
                        <div>
                            <h3>{{this.name}}</h3>
                            <p class="master-community-meta">
                                <code>{{this.slug}}</code>
                                · {{#if this.location.city}}{{this.location.city}}{{else}}{{t 'no_city'}}{{/if}}
                                · {{#if this.location.timezone}}{{this.location.timezone}}{{else}}Asia/Novosibirsk{{/if}}
                                · {{this.language}}/{{this.adminLanguage}}
                            </p>
                            {{#if this.provisioning.photosDriveUrl}}
                            <p class="master-community-provision">
                                <span>{{t 'wizard_review_photos_drive'}}:</span>
                                <a href="{{this.provisioning.photosDriveUrl}}" target="_blank" rel="noopener">{{this.provisioning.photosDriveUrl}}</a>
                            </p>
                            {{/if}}
                            {{#if this.provisioning.contactFiles.length}}
                            <p class="master-community-provision">{{t 'wizard_contact_files'}}: {{this.provisioning.contactFiles.length}}</p>
                            {{/if}}
                        </div>
                        <div class="master-community-card-links">
                            <a href="/s/{{this.slug}}" class="btn master-btn master-btn-secondary btn-sm" target="_blank" rel="noopener">
                                <svg class="master-btn-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M21 3H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h5v2h8v-2h5c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2m0 14H3V5h18v12Z"/></svg>
                                {{t 'board'}}
                            </a>
                            <a href="/admin/login" class="btn master-btn master-btn-secondary btn-sm" target="_blank" rel="noopener">
                                <svg class="master-btn-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4m0 2.18c2.53.77 4.5 2.53 5.82 4.82H6.18C7.5 5.71 9.47 3.95 12 3.18M12 7a2 2 0 0 1 2 2 2 2 0 0 1-2 2 2 2 0 0 1-2-2 2 2 0 0 1 2-2m0 6.75c2.53 0 4.77.93 6.5 2.43V17c0 .55-.45 1-1 1H6.5c-.55 0-1-.45-1-1v-.82c1.73-1.5 3.97-2.43 6.5-2.43Z"/></svg>
                                {{t 'admin'}}
                            </a>
                            <button type="button" class="btn master-btn master-btn-secondary btn-sm master-toggle-edit" data-label-edit="{{t 'edit'}}" data-label-close="{{t 'close'}}" aria-expanded="false">
                                <svg class="master-btn-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M20.71 7.04c.39-.39.39-1.04 0-1.41l-2.34-2.34c-.37-.39-1.02-.39-1.41 0l-1.84 1.83 3.75 3.75M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25Z"/></svg>
                                <span class="master-toggle-edit-label">{{t 'edit'}}</span>
                            </button>
                        </div>
                    </header>
                    <div class="master-community-edit" hidden>
                        <form method="POST" action="/master/edit" class="master-community-form" data-location-picker="edit-{{this._id}}">
                            <input type="hidden" name="id" value="{{this._id}}">
                            <div class="master-form-grid">
                                <div class="master-field">
                                    <label>{{t 'community_name'}}</label>
                                    <input type="text" name="name" class="form-control master-input" value="{{this.name}}" required>
                                </div>
                                <div class="master-field">
                                    <label>{{t 'admin_slug'}}</label>
                                    <input type="text" name="slug" class="form-control master-input master-slug-input" value="{{this.slug}}" required>
                                </div>
                                <div class="master-field">
                                    <label>{{t 'new_password_optional'}}</label>
                                    <input type="password" name="adminPassword" class="form-control master-input" placeholder="{{t 'new_password_placeholder'}}" autocomplete="new-password">
                                </div>
                            </div>

                            <div class="master-lang-block">
                                <h3 class="master-location-title">{{t 'languages_section'}}</h3>
                                <div class="master-form-grid">
                                    <div class="master-field">
                                        <label>{{t 'display_language'}}</label>
                                        <select name="language" class="form-control master-input">
                                            <option value="ru" {{#if (eq this.language 'ru')}}selected{{/if}}>{{t 'lang_ru'}}</option>
                                            <option value="en" {{#if (eq this.language 'en')}}selected{{/if}}>{{t 'lang_en'}}</option>
                                            <option value="he" {{#if (eq this.language 'he')}}selected{{/if}}>{{t 'lang_he'}}</option>
                                        </select>
                                    </div>
                                    <div class="master-field">
                                        <label>{{t 'admin_language'}}</label>
                                        <select name="adminLanguage" class="form-control master-input">
                                            <option value="ru" {{#if (eq this.adminLanguage 'ru')}}selected{{/if}}>{{t 'lang_ru'}}</option>
                                            <option value="en" {{#if (eq this.adminLanguage 'en')}}selected{{/if}}>{{t 'lang_en'}}</option>
                                            <option value="he" {{#if (eq this.adminLanguage 'he')}}selected{{/if}}>{{t 'lang_he'}}</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="master-location-block">
                                <h3 class="master-location-title">{{t 'location'}}</h3>
                                <div class="master-location-search-wrap">
                                    <label>{{t 'search_city'}}</label>
                                    <input type="search" class="form-control master-input master-city-search" value="{{this.location.city}}" placeholder="{{t 'search_city_placeholder'}}" autocomplete="off">
                                    <div class="master-city-results" hidden></div>
                                </div>
                                <input type="hidden" name="city" class="master-city-hidden" value="{{this.location.city}}">
                                <input type="hidden" name="lat" class="master-lat-hidden" value="{{this.location.lat}}">
                                <input type="hidden" name="long" class="master-lng-hidden" value="{{this.location.long}}">
                                <div class="master-coords-row">
                                    <div class="master-field">
                                        <label>{{t 'latitude'}}</label>
                                        <input type="text" class="form-control master-input master-lat-display" readonly value="{{this.location.lat}}">
                                    </div>
                                    <div class="master-field">
                                        <label>{{t 'longitude'}}</label>
                                        <input type="text" class="form-control master-input master-lng-display" readonly value="{{this.location.long}}">
                                    </div>
                                    <div class="master-field master-field-wide">
                                        <label>{{t 'timezone'}}</label>
                                        <input type="text" name="timezone" class="form-control master-input master-timezone-input" value="{{#if this.location.timezone}}{{this.location.timezone}}{{else}}Asia/Novosibirsk{{/if}}">
                                    </div>
                                </div>
                                <div class="master-map" data-default-lat="{{this.location.lat}}" data-default-lng="{{this.location.long}}"></div>
                            </div>

                            <div class="master-edit-actions">
                                <button type="submit" class="btn master-btn master-btn-primary">
                                    <svg class="master-btn-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4m-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3m3-10H5V5h10v4Z"/></svg>
                                    {{t 'save_changes'}}
                                </button>
                                <button type="submit" formaction="/master/delete" formmethod="POST" class="btn master-btn master-btn-danger" onclick="return confirm('{{t 'delete_confirm'}}');">
                                    <svg class="master-btn-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12M19 4h-3.5l-1-1h-5l-1 1H5v2h14V4Z"/></svg>
                                    {{t 'delete'}}
                                </button>
                            </div>
                        </form>
                    </div>
                </article>
                {{/each}}
            </div>
            {{else}}
            <p class="master-empty">{{t 'no_communities'}}</p>
            {{/if}}
        </div>
    </section>
</div>
