<div class="modal fade admin-modal" id="personCardModal" tabindex="-1" role="dialog" aria-labelledby="personCardModalTitle" aria-modal="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="personCardModalTitle">{{t 'person_card_title'}}</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
            </div>
            <div class="modal-body">
                <div class="admin-person-card-layout">
                    <div class="admin-person-card-preview" id="personCardPreview"
                        style="--primary-color: {{synagogue.theme.primaryColor}}; --text-color: {{synagogue.theme.textColor}}; --accent-color: {{synagogue.theme.accentColor}};">
                        <img class="admin-person-card-photo d-none" id="personCardPhoto" alt="">
                        <div class="admin-person-card-photo admin-person-card-placeholder d-none" id="personCardPlaceholder" aria-hidden="true"></div>
                        <div class="admin-person-card-body">
                            <h2 id="personCardName"></h2>
                            <p id="personCardDates"></p>
                        </div>
                        <div class="admin-person-card-candle" aria-hidden="true">🕯</div>
                    </div>
                    <div class="admin-person-card-details">
                        <div class="admin-person-card-section">
                            <h3>{{t 'person_card_biography'}}</h3>
                            <div class="admin-person-card-bio" id="personCardBio"></div>
                        </div>
                        <div class="admin-person-card-section" id="personCardContactSection">
                            <h3>{{t 'contact_section'}}</h3>
                            <p id="personCardNoContact" class="seed-notice">{{t 'yahrzeit_no_contact'}}</p>
                            <div id="personCardContactsList" class="admin-person-card-contacts"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer admin-person-card-footer">
                <div id="personCardSendActions" class="admin-person-card-send-actions"></div>
                <button type="button" class="btn-admin btn-admin-secondary btn-admin-with-icon" id="personCardEditBtn">{{{adminIcon 'edit' class='btn-admin-inline-icon'}}}{{t 'edit'}}</button>
                <button type="button" class="btn-admin btn-admin-danger btn-admin-with-icon" id="personCardDeleteBtn">{{{adminIcon 'delete' class='btn-admin-inline-icon'}}}{{t 'delete'}}</button>
            </div>
            <form method="POST" action="/admin/{{synagogue.slug}}/people/delete" id="personCardDeleteForm" class="d-none">
                <input type="hidden" name="id" id="personCardDeleteId">
            </form>
        </div>
    </div>
</div>
