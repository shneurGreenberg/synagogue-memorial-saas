<div class="admin-page people-page">
    <header class="admin-page-header">
        <div>
            <h1>{{t 'people'}}</h1>
            <p class="admin-subtitle">{{t 'people_subtitle'}}</p>
        </div>
        <div class="header-actions">
            {{#if adminPermissions.peopleImport}}
            <button type="button" class="btn-admin btn-admin-secondary" data-toggle="modal" data-target="#importPeopleModal">
                {{t 'import_people'}}
            </button>
            {{/if}}
            <button type="button" class="btn-admin btn-admin-primary" data-toggle="modal" data-target="#addPersonModal">
                + {{t 'add_person'}}
            </button>
        </div>
    </header>

    {{#if imported}}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{t 'import_done'}}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {{/if}}
    {{#if importError}}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{t 'import_error'}}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {{/if}}

    <div class="people-toolbar">
        <input type="search" id="peopleSearch" class="form-control admin-input" style="max-width: 300px; flex: 1;"
            placeholder="{{t 'search_people'}}" aria-label="{{t 'search_people'}}">
        <select id="peopleSort" class="form-control admin-input" style="max-width: 200px;" aria-label="{{t 'sort_label'}}">
            <option value="name">{{t 'sort_by_name'}}</option>
            <option value="date">{{t 'sort_by_date'}}</option>
        </select>
    </div>

    <div class="people-list" id="peopleList">
        {{#each synagogue.people}}
        <article class="person-row" data-name="{{this.name}}" data-id="{{this.id}}"
            data-date="{{this.gregorianDateOfDeath.year}}-{{this.gregorianDateOfDeath.month}}-{{this.gregorianDateOfDeath.date}}">
            {{#if this.photo}}
            <img src="/photos/{{this.photo}}" class="person-photo" alt="{{this.name}}"
                onerror="this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');">
            <span class="person-photo person-photo-placeholder d-none" aria-hidden="true">{{initials this.name}}</span>
            {{else}}
            <span class="person-photo person-photo-placeholder" aria-hidden="true">{{initials this.name}}</span>
            {{/if}}
            <div class="person-meta">
                <strong>{{this.name}}</strong>
                <small>{{t 'date_of_death'}}:
                    {{this.gregorianDateOfDeath.date}}/{{this.gregorianDateOfDeath.month}}/{{this.gregorianDateOfDeath.year}}</small>
            </div>
            <div class="person-actions">
                <button type="button" class="btn-admin btn-admin-secondary edit-btn" data-id="{{this.id}}">{{t 'edit'}}</button>
                <form method="POST" action="/admin/{{../synagogue.slug}}/people/delete" class="d-inline"
                    onsubmit="return confirm('{{t 'are_you_sure'}}');">
                    <input type="hidden" name="id" value="{{this.id}}">
                    <button type="submit" class="btn-admin btn-admin-danger">{{t 'delete'}}</button>
                </form>
            </div>
        </article>
        {{/each}}
    </div>
</div>

<script id="people-data" type="application/json">{{{json synagogue.people}}}</script>

{{#if adminPermissions.peopleImport}}
<!-- Import People Modal -->
<div class="modal fade admin-modal" id="importPeopleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form method="POST" action="/admin/{{synagogue.slug}}/people/import">
                <div class="modal-header">
                    <h5 class="modal-title">{{t 'import_people'}}</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
                </div>
                <div class="modal-body">
                    <p class="seed-notice">{{t 'import_people_help'}}</p>
                    <p class="seed-notice">{{t 'import_schema_hint'}}</p>
                    <pre class="import-schema" aria-hidden="true">[
  {
    "name": "Example Name",
    "gregorianDateOfDeath": { "month": 3, "date": 15, "year": 2020 },
    "photo": "",
    "title": "",
    "text": "Biography text"
  }
]</pre>
                    <div class="form-field">
                        <label for="importJson">JSON</label>
                        <textarea name="json" id="importJson" class="form-control" rows="12" required
                            placeholder='[{"name":"...","gregorianDateOfDeath":{"month":1,"date":1,"year":2020}}]'></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-admin btn-admin-ghost" data-dismiss="modal">{{t 'cancel'}}</button>
                    <button type="submit" class="btn-admin btn-admin-primary">{{t 'import_submit'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>
{{/if}}

<!-- Add Person Modal -->
<div class="modal fade admin-modal" id="addPersonModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="POST" action="/admin/{{synagogue.slug}}/people/add" enctype="multipart/form-data"
                class="person-form" data-preview="addPhotoPreview">
                <div class="modal-header">
                    <h5 class="modal-title">{{t 'add_person'}}</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="person-form-layout">
                        <div class="photo-upload-zone">
                            <div class="photo-preview-wrap" id="addPhotoPreview">
                                <span class="photo-preview-empty">{{t 'upload_photo'}}</span>
                            </div>
                            <label class="file-drop-label">
                                {{t 'upload_photo'}}
                                <input type="file" name="photo" accept="image/*" data-preview-target="addPhotoPreview">
                            </label>
                            <span class="seed-notice">{{t 'photo_hint'}}</span>
                        </div>
                        <div class="person-form-fields">
                            <div class="form-field">
                                <label for="addName">{{t 'name'}}</label>
                                <input type="text" name="name" id="addName" class="form-control" required>
                            </div>
                            <div class="form-field">
                                <label>{{t 'date_gregorian'}}</label>
                                <div class="date-row">
                                    <input type="number" name="date" class="form-control" placeholder="{{t 'day'}}" required>
                                    <input type="number" name="month" class="form-control" placeholder="{{t 'month'}}" required>
                                    <input type="number" name="year" class="form-control" placeholder="{{t 'year'}}" required>
                                </div>
                            </div>
                            <div class="form-field">
                                <label for="addText">{{t 'biography'}}</label>
                                <textarea name="text" id="addText" class="form-control"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-admin btn-admin-ghost" data-dismiss="modal">{{t 'cancel'}}</button>
                    <button type="submit" class="btn-admin btn-admin-primary">{{t 'save'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Person Modal -->
<div class="modal fade admin-modal" id="editPersonModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="POST" action="/admin/{{synagogue.slug}}/people/edit" enctype="multipart/form-data"
                class="person-form" data-preview="editPhotoPreview">
                <input type="hidden" name="id" id="editId">
                <div class="modal-header">
                    <h5 class="modal-title">{{t 'edit'}}</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="person-form-layout">
                        <div class="photo-upload-zone">
                            <div class="photo-preview-wrap" id="editPhotoPreview">
                                <span class="photo-preview-empty">{{t 'no_photo'}}</span>
                            </div>
                            <label class="file-drop-label">
                                {{t 'change_photo'}}
                                <input type="file" name="photo" accept="image/*" data-preview-target="editPhotoPreview">
                            </label>
                            <div class="form-check-modern mt-2">
                                <input type="checkbox" name="deletePhoto" id="deletePhotoCheck">
                                <label for="deletePhotoCheck">{{t 'delete_photo'}}</label>
                            </div>
                        </div>
                        <div class="person-form-fields">
                            <div class="form-field">
                                <label for="editName">{{t 'name'}}</label>
                                <input type="text" name="name" id="editName" class="form-control" required>
                            </div>
                            <div class="form-field">
                                <label>{{t 'date_gregorian'}}</label>
                                <div class="date-row">
                                    <input type="number" name="date" id="editDate" class="form-control" placeholder="{{t 'day'}}" required>
                                    <input type="number" name="month" id="editMonth" class="form-control" placeholder="{{t 'month'}}" required>
                                    <input type="number" name="year" id="editYear" class="form-control" placeholder="{{t 'year'}}" required>
                                </div>
                            </div>
                            <div class="form-field">
                                <label for="editText">{{t 'biography'}}</label>
                                <textarea name="text" id="editText" class="form-control"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-admin btn-admin-ghost" data-dismiss="modal">{{t 'cancel'}}</button>
                    <button type="submit" class="btn-admin btn-admin-primary">{{t 'save_changes'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function () {
        const people = JSON.parse(document.getElementById('people-data').textContent);
        const peopleById = {};
        people.forEach(function (person) {
            peopleById[person.id] = person;
        });

        const list = document.getElementById('peopleList');
        const searchInput = document.getElementById('peopleSearch');
        const sortSelect = document.getElementById('peopleSort');

        function setPreviewImage(container, src, alt) {
            container.innerHTML = '<img src="' + src + '" alt="' + (alt || '') + '">';
        }

        document.querySelectorAll('input[type="file"][data-preview-target]').forEach(function (input) {
            input.addEventListener('change', function () {
                const container = document.getElementById(input.getAttribute('data-preview-target'));
                const file = input.files && input.files[0];
                if (!file) {
                    return;
                }
                const reader = new FileReader();
                reader.onload = function (e) {
                    setPreviewImage(container, e.target.result, file.name);
                };
                reader.readAsDataURL(file);
            });
        });

        function applyFilters() {
            const query = searchInput.value.trim().toLowerCase();
            const sortBy = sortSelect.value;
            const rows = Array.from(list.querySelectorAll('.person-row'));

            rows.forEach(function (row) {
                const name = (row.getAttribute('data-name') || '').toLowerCase();
                row.style.display = !query || name.includes(query) ? '' : 'none';
            });

            const visible = rows.filter(function (row) { return row.style.display !== 'none'; });

            visible.sort(function (a, b) {
                if (sortBy === 'date') {
                    return a.getAttribute('data-date').localeCompare(b.getAttribute('data-date'));
                }
                return a.getAttribute('data-name').localeCompare(b.getAttribute('data-name'));
            });

            visible.forEach(function (row) {
                list.appendChild(row);
            });
        }

        searchInput.addEventListener('input', applyFilters);
        sortSelect.addEventListener('change', applyFilters);

        document.querySelectorAll('.edit-btn').forEach(function (button) {
            button.addEventListener('click', function () {
                const id = Number(button.getAttribute('data-id'));
                const person = peopleById[id];
                if (!person) {
                    return;
                }

                document.getElementById('editId').value = person.id;
                document.getElementById('editName').value = person.name || '';
                document.getElementById('editDate').value = person.gregorianDateOfDeath.date;
                document.getElementById('editMonth').value = person.gregorianDateOfDeath.month;
                document.getElementById('editYear').value = person.gregorianDateOfDeath.year;
                document.getElementById('editText').value = person.text || '';
                document.getElementById('deletePhotoCheck').checked = false;

                const preview = document.getElementById('editPhotoPreview');
                if (person.photo) {
                    setPreviewImage(preview, '/photos/' + person.photo, person.name || '');
                } else {
                    preview.innerHTML = '<span class="photo-preview-empty">{{t "no_photo"}}</span>';
                }

                $('#editPersonModal').modal('show');
            });
        });
    })();
</script>
