<div class="admin-page people-page" data-synagogue-slug="{{synagogue.slug}}" data-contact-directory-count="{{synagogue.contactDirectoryCount}}" data-contact-directory-count-label="{{t 'contact_directory_count'}}" data-manage-contacts-empty="{{t 'manage_contacts_empty'}}" data-manage-contacts-delete-confirm="{{t 'manage_contacts_delete_confirm'}}" data-manage-contacts-saved="{{t 'manage_contacts_saved'}}" data-manage-contacts-deleted="{{t 'manage_contacts_deleted'}}" data-edit-label="{{t 'edit'}}" data-date-label="{{t 'date_of_death'}}" data-delete-confirm="{{t 'are_you_sure'}}" data-delete-photo-confirm="{{t 'delete_photo_confirm'}}" data-no-bio-label="{{t 'person_card_no_biography'}}" data-send-label="{{t 'yahrzeit_send_contact'}}" data-download-tile-label="{{t 'yahrzeit_download_tile'}}" data-platform-whatsapp="{{t 'contact_platform_whatsapp'}}" data-platform-telegram="{{t 'contact_platform_telegram'}}" data-platform-max="{{t 'contact_platform_max'}}" data-platform-sms="{{t 'contact_platform_sms'}}" data-platform-email="{{t 'contact_platform_email'}}" data-contact-suggestion-label="{{t 'contact_pick_suggestion'}}">
    <header class="admin-page-header">
        <div>
            <h1>{{t 'people'}}</h1>
            <p class="admin-subtitle">{{t 'people_subtitle'}}</p>
        </div>
        <div class="header-actions">
            {{#if adminPermissions.peopleImport}}
            <button type="button" class="btn-admin btn-admin-secondary btn-admin-with-icon" data-toggle="modal" data-target="#importPeopleModal">
                {{{adminIcon 'import' class='btn-admin-inline-icon'}}}
                {{t 'import_people'}}
            </button>
            {{/if}}
            <button type="button" class="btn-admin btn-admin-secondary btn-admin-with-icon" data-toggle="modal" data-target="#importContactsModal">
                {{{adminIcon 'import' class='btn-admin-inline-icon'}}}
                {{t 'import_contacts'}}
            </button>
            <button type="button" class="btn-admin btn-admin-secondary btn-admin-with-icon" data-toggle="modal" data-target="#manageContactsModal" id="manageContactsBtn">
                {{{adminIcon 'edit' class='btn-admin-inline-icon'}}}
                {{t 'manage_contacts'}}
            </button>
            <button type="button" class="btn-admin btn-admin-primary btn-admin-with-icon" data-toggle="modal" data-target="#addPersonModal">
                {{{adminIcon 'add' class='btn-admin-inline-icon'}}}
                {{t 'add_person'}}
            </button>
        </div>
    </header>

    {{#if imported}}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{t 'import_done'}}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {{/if}}
    {{#if importError}}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{t 'import_error'}}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {{/if}}
    {{#if contactsImported}}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{t 'import_contacts_done'}}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {{/if}}
    {{#if contactsImportError}}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{t 'import_contacts_error'}}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {{/if}}

    <div class="people-toolbar">
        <input type="search" id="peopleSearch" class="form-control admin-input" style="max-width: 300px; flex: 1;"
            placeholder="{{t 'search_people'}}" aria-label="{{t 'search_people'}}">
        <button type="button" class="seed-notice people-directory-count people-directory-count-btn" id="contactDirectoryCount" hidden data-toggle="modal" data-target="#manageContactsModal"></button>
    </div>

    <div class="people-list" id="peopleList">
        {{#each synagogue.people}}
        <article class="person-row person-row-clickable" data-name="{{this.name}}" data-id="{{this.id}}"
            data-date="{{this.gregorianDateOfDeath.year}}-{{this.gregorianDateOfDeath.month}}-{{this.gregorianDateOfDeath.date}}">
            {{#if this.photo}}
            <span class="person-photo-wrap">
                <img class="person-photo lazy-person-photo" alt="{{this.name}}"
                    data-thumb-src="{{photoThumbUrl this.photo}}"
                    data-full-src="/photos/{{this.photo}}"
                    decoding="async"
                    onerror="this.closest('.person-photo-wrap').classList.add('d-none'); this.closest('.person-row').querySelector('.person-photo-placeholder').classList.remove('d-none');">
            </span>
            <span class="person-photo-placeholder d-none" aria-hidden="true">{{initials this.name}}</span>
            {{else}}
            <span class="person-photo-placeholder" aria-hidden="true">{{initials this.name}}</span>
            {{/if}}
            <div class="person-meta">
                <strong>{{this.name}}</strong>
                <small>{{t 'date_of_death'}}:
                    {{this.gregorianDateOfDeath.date}}/{{this.gregorianDateOfDeath.month}}/{{this.gregorianDateOfDeath.year}}</small>
            </div>
        </article>
        {{/each}}
    </div>
</div>

<script id="people-data" type="application/json">{{{json synagogue.people}}}</script>

{{#if adminPermissions.peopleImport}}
<!-- Import People Modal -->
<div class="modal fade admin-modal" id="importPeopleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form method="POST" action="/admin/{{synagogue.slug}}/people/import">
                <div class="modal-header">
                    <h5 class="modal-title">{{t 'import_people'}}</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
                </div>
                <div class="modal-body">
                    <p class="seed-notice">{{t 'import_people_help'}}</p>
                    <p class="seed-notice">{{t 'import_schema_hint'}}</p>
                    <pre class="import-schema" aria-hidden="true">[
  {
    "name": "Example Name",
    "gregorianDateOfDeath": { "month": 3, "date": 15, "year": 2020 },
    "photo": "",
    "title": "",
    "text": "Biography text"
  }
]</pre>
                    <div class="form-field">
                        <label for="importJson">JSON</label>
                        <textarea name="json" id="importJson" class="form-control" rows="12" required
                            placeholder='[{"name":"...","gregorianDateOfDeath":{"month":1,"date":1,"year":2020}}]'></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-admin btn-admin-ghost btn-admin-with-icon" data-dismiss="modal">{{{adminIcon 'cancel' class='btn-admin-inline-icon'}}}{{t 'cancel'}}</button>
                    <button type="submit" class="btn-admin btn-admin-primary btn-admin-with-icon">{{{adminIcon 'import' class='btn-admin-inline-icon'}}}{{t 'import_submit'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>
{{/if}}

<!-- Import Contacts Modal -->
<div class="modal fade admin-modal" id="importContactsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="importContactsForm" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title">{{t 'import_contacts'}}</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
                </div>
                <div class="modal-body">
                    <p class="seed-notice">{{t 'import_contacts_help'}}</p>
                    <div class="form-field">
                        <label for="importContactsFile">CSV / vCard</label>
                        <input type="file" name="file" id="importContactsFile" class="form-control" accept=".csv,.vcf,.txt,text/csv,text/vcard" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-admin btn-admin-ghost btn-admin-with-icon" data-dismiss="modal">{{{adminIcon 'cancel' class='btn-admin-inline-icon'}}}{{t 'cancel'}}</button>
                    <button type="submit" class="btn-admin btn-admin-primary btn-admin-with-icon" id="importContactsSubmit">{{{adminIcon 'import' class='btn-admin-inline-icon'}}}{{t 'import_contacts_submit'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Manage Contacts Modal -->
<div class="modal fade admin-modal" id="manageContactsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title">{{t 'manage_contacts_title'}}</h5>
                    <p class="seed-notice manage-contacts-subtitle">{{t 'manage_contacts_subtitle'}}</p>
                </div>
                <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
            </div>
            <div class="modal-body">
                <div class="manage-contacts-toolbar">
                    <input type="search" id="manageContactsSearch" class="form-control admin-input" placeholder="{{t 'manage_contacts_search'}}" aria-label="{{t 'manage_contacts_search'}}">
                    <button type="button" class="btn-admin btn-admin-secondary btn-admin-with-icon" id="manageContactsAddBtn">
                        {{{adminIcon 'add' class='btn-admin-inline-icon'}}}{{t 'manage_contacts_add'}}
                    </button>
                </div>
                <div class="manage-contacts-list-wrap">
                    <table class="manage-contacts-table" id="manageContactsTable">
                        <thead>
                            <tr>
                                <th scope="col">{{t 'contact_name'}}</th>
                                <th scope="col">{{t 'contact_phone'}}</th>
                                <th scope="col">{{t 'contact_email'}}</th>
                                <th scope="col" class="manage-contacts-actions-col">{{t 'actions'}}</th>
                            </tr>
                        </thead>
                        <tbody id="manageContactsList"></tbody>
                    </table>
                    <p class="seed-notice manage-contacts-empty" id="manageContactsEmpty" hidden>{{t 'manage_contacts_empty'}}</p>
                </div>
                <form id="manageContactForm" class="manage-contact-form" hidden>
                    <input type="hidden" id="manageContactId" value="">
                    <div class="form-field">
                        <label for="manageContactName">{{t 'contact_name'}}</label>
                        <input type="text" id="manageContactName" class="form-control" maxlength="120">
                    </div>
                    <div class="form-field">
                        <label for="manageContactPhone">{{t 'contact_phone'}}</label>
                        <input type="tel" id="manageContactPhone" class="form-control" maxlength="30">
                    </div>
                    <div class="form-field">
                        <label for="manageContactEmail">{{t 'contact_email'}}</label>
                        <input type="email" id="manageContactEmail" class="form-control" maxlength="200">
                    </div>
                    <div class="manage-contact-form-actions">
                        <button type="button" class="btn-admin btn-admin-ghost" id="manageContactCancelBtn">{{t 'cancel'}}</button>
                        <button type="submit" class="btn-admin btn-admin-primary btn-admin-with-icon" id="manageContactSaveBtn">{{{adminIcon 'save' class='btn-admin-inline-icon'}}}{{t 'manage_contacts_save'}}</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Add Person Modal -->
<div class="modal fade admin-modal" id="addPersonModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="POST" action="/admin/{{synagogue.slug}}/people/add" enctype="multipart/form-data"
                class="person-form" data-preview="addPhotoPreview">
                <div class="modal-header">
                    <h5 class="modal-title">{{t 'add_person'}}</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="person-form-layout">
                        <div class="photo-upload-zone">
                            <div class="photo-crop-editor" data-form="add">
                                <div class="photo-preview-wrap photo-crop-viewport" id="addPhotoPreview">
                                    <span class="photo-preview-empty">{{t 'upload_photo'}}</span>
                                </div>
                                <div class="photo-crop-controls" hidden>
                                    <label class="photo-crop-zoom-label" for="addPhotoCropZoom">{{t 'photo_crop_zoom'}}</label>
                                    <input type="range" id="addPhotoCropZoom" class="photo-crop-zoom" min="1" max="3" step="0.05" value="1">
                                    <span class="seed-notice">{{t 'photo_crop_hint'}}</span>
                                </div>
                                <input type="hidden" name="photoCropX" class="photo-crop-x" value="50">
                                <input type="hidden" name="photoCropY" class="photo-crop-y" value="50">
                                <input type="hidden" name="photoCropZoom" class="photo-crop-zoom-value" value="1">
                            </div>
                            <label class="file-drop-label">
                                {{t 'upload_photo'}}
                                <input type="file" name="photo" accept="image/*" data-crop-editor="add">
                            </label>
                            <span class="seed-notice">{{t 'photo_hint'}}</span>
                        </div>
                        <div class="person-form-fields">
                            <div class="form-field">
                                <label for="addName">{{t 'name'}}</label>
                                <input type="text" name="name" id="addName" class="form-control" required placeholder="{{t 'name_placeholder'}}">
                            </div>
                            <div class="form-field">
                                <label>{{t 'date_gregorian'}}</label>
                                <div class="date-row">
                                    <input type="number" name="date" class="form-control" placeholder="{{t 'day'}}" required>
                                    <input type="number" name="month" class="form-control" placeholder="{{t 'month'}}" required>
                                    <input type="number" name="year" class="form-control" placeholder="{{t 'year'}}" required>
                                </div>
                            </div>
                            <div class="form-field">
                                <label for="addText">{{t 'biography'}}</label>
                                <textarea name="text" id="addText" class="form-control"></textarea>
                            </div>
                            {{> admin-person-contacts}}
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-admin btn-admin-ghost btn-admin-with-icon" data-dismiss="modal">{{{adminIcon 'cancel' class='btn-admin-inline-icon'}}}{{t 'cancel'}}</button>
                    <button type="submit" class="btn-admin btn-admin-primary btn-admin-with-icon">{{{adminIcon 'save' class='btn-admin-inline-icon'}}}{{t 'save'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Person Modal -->
<div class="modal fade admin-modal" id="editPersonModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="POST" action="/admin/{{synagogue.slug}}/people/edit" enctype="multipart/form-data"
                class="person-form" data-preview="editPhotoPreview">
                <input type="hidden" name="id" id="editId">
                <div class="modal-header">
                    <h5 class="modal-title">{{t 'edit_deceased_details'}}</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="person-form-layout">
                        <div class="photo-upload-zone">
                            <div class="photo-crop-editor" data-form="edit">
                                <div class="photo-preview-wrap photo-crop-viewport" id="editPhotoPreview">
                                    <span class="photo-preview-empty">{{t 'no_photo'}}</span>
                                </div>
                                <div class="photo-crop-controls" hidden>
                                    <label class="photo-crop-zoom-label" for="editPhotoCropZoom">{{t 'photo_crop_zoom'}}</label>
                                    <input type="range" id="editPhotoCropZoom" class="photo-crop-zoom" min="1" max="3" step="0.05" value="1">
                                    <span class="seed-notice">{{t 'photo_crop_hint'}}</span>
                                </div>
                                <input type="hidden" name="photoCropX" class="photo-crop-x" value="50">
                                <input type="hidden" name="photoCropY" class="photo-crop-y" value="50">
                                <input type="hidden" name="photoCropZoom" class="photo-crop-zoom-value" value="1">
                            </div>
                            <label class="file-drop-label">
                                {{t 'change_photo'}}
                                <input type="file" name="photo" accept="image/*" data-crop-editor="edit">
                            </label>
                            <input type="hidden" name="deletePhoto" id="editDeletePhoto" value="">
                            <button type="button" class="btn-admin btn-admin-danger btn-delete-photo btn-admin-with-icon" id="editDeletePhotoBtn">
                                <svg class="btn-admin-inline-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                                {{t 'delete_photo'}}
                            </button>
                        </div>
                        <div class="person-form-fields">
                            <div class="form-field">
                                <label for="editName">{{t 'name'}}</label>
                                <input type="text" name="name" id="editName" class="form-control" required placeholder="{{t 'name_placeholder'}}">
                            </div>
                            <div class="form-field">
                                <label>{{t 'date_gregorian'}}</label>
                                <div class="date-row">
                                    <input type="number" name="date" id="editDate" class="form-control" placeholder="{{t 'day'}}" required>
                                    <input type="number" name="month" id="editMonth" class="form-control" placeholder="{{t 'month'}}" required>
                                    <input type="number" name="year" id="editYear" class="form-control" placeholder="{{t 'year'}}" required>
                                </div>
                            </div>
                            <div class="form-field">
                                <label for="editText">{{t 'biography'}}</label>
                                <textarea name="text" id="editText" class="form-control"></textarea>
                            </div>
                            {{> admin-person-contacts}}
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-admin btn-admin-ghost btn-admin-with-icon" data-dismiss="modal">{{{adminIcon 'cancel' class='btn-admin-inline-icon'}}}{{t 'cancel'}}</button>
                    <button type="submit" class="btn-admin btn-admin-primary btn-admin-with-icon">{{{adminIcon 'save' class='btn-admin-inline-icon'}}}{{t 'save_changes'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>

{{> admin-person-contact-template}}
{{> admin-person-card-modal}}
