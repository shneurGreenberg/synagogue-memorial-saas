<h2>{{t 'people'}}</h2>
<button class="btn btn-primary mb-3" data-toggle="modal" data-target="#addPersonModal">{{t 'add_person'}}</button>
<style>
    .person-photo {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 50%;
    }
</style>
<table class="table">
    <thead>
        <tr>
            <th>{{t 'photo'}}</th>
            <th>ID</th>
            <th>{{t 'name'}}</th>
            <th>{{t 'date_of_death'}}</th>
            <th>{{t 'actions'}}</th>
        </tr>
    </thead>
    <tbody>
        {{#each synagogue.people}}
        <tr>
            <td>
                {{#if this.photo}}
                <img src="/photos/{{this.photo}}" class="person-photo">
                {{else}}
                <span>{{t 'no_photo'}}</span>
                {{/if}}
            </td>
            <td>{{this.id}}</td>
            <td>{{this.name}}</td>
            <td>{{this.gregorianDateOfDeath.date}}/{{this.gregorianDateOfDeath.month}}/{{this.gregorianDateOfDeath.year}}
            </td>
            <td>
                <button class="btn btn-sm btn-info edit-btn" data-id="{{this.id}}" data-name="{{this.name}}"
                    data-date="{{this.gregorianDateOfDeath.date}}" data-month="{{this.gregorianDateOfDeath.month}}"
                    data-year="{{this.gregorianDateOfDeath.year}}" data-text="{{this.text}}" data-photo="{{this.photo}}"
                    data-toggle="modal" data-target="#editPersonModal">{{t 'edit'}}</button>
                <form method="POST" action="/admin/{{../synagogue.slug}}/people/delete" class="d-inline"
                    onsubmit="return confirm('{{t 'are_you_sure'}}');">
                    <input type="hidden" name="id" value="{{this.id}}">
                    <button type="submit" class="btn btn-sm btn-danger">{{t 'delete'}}</button>
                </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

<!-- Add Person Modal -->
<div class="modal fade" id="addPersonModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="POST" action="/admin/{{synagogue.slug}}/people/add" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title">{{t 'add_person'}}</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>{{t 'name'}}</label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label>{{t 'date_gregorian'}}</label>
                        <div class="row">
                            <div class="col"><input type="number" name="date" class="form-control" placeholder="DD"
                                    required></div>
                            <div class="col"><input type="number" name="month" class="form-control" placeholder="MM"
                                    required></div>
                            <div class="col"><input type="number" name="year" class="form-control" placeholder="YYYY"
                                    required></div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>{{t 'text'}}</label>
                        <textarea name="text" class="form-control"></textarea>
                    </div>
                    <div class="form-group">
                        <label>{{t 'image'}}</label>
                        <input type="file" name="photo" class="form-control-file">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">{{t 'save'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>

<!-- Edit Person Modal -->
<div class="modal fade" id="editPersonModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="POST" action="/admin/{{synagogue.slug}}/people/edit" enctype="multipart/form-data">
                <input type="hidden" name="id" id="editId">
                <div class="modal-header">
                    <h5 class="modal-title">{{t 'edit'}}</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>{{t 'name'}}</label>
                        <input type="text" name="name" id="editName" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label>{{t 'date_gregorian'}}</label>
                        <div class="row">
                            <div class="col"><input type="number" name="date" id="editDate" class="form-control"
                                    placeholder="DD" required></div>
                            <div class="col"><input type="number" name="month" id="editMonth" class="form-control"
                                    placeholder="MM" required></div>
                            <div class="col"><input type="number" name="year" id="editYear" class="form-control"
                                    placeholder="YYYY" required></div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>{{t 'text'}}</label>
                        <textarea name="text" id="editText" class="form-control"></textarea>
                    </div>
                    <div class="form-group">
                        <label>{{t 'current_photo'}}</label>
                        <div id="currentPhotoContainer"></div>
                    </div>
                    <div class="form-group">
                        <label>{{t 'change_photo'}}</label>
                        <input type="file" name="photo" class="form-control-file">
                    </div>
                    <div class="form-group form-check">
                        <input type="checkbox" name="deletePhoto" class="form-check-input" id="deletePhotoCheck">
                        <label class="form-check-label" for="deletePhotoCheck">{{t 'delete_photo'}}</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">{{t 'save_changes'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('.edit-btn').click(function () {
            const btn = $(this);
            $('#editId').val(btn.data('id'));
            $('#editName').val(btn.data('name'));
            $('#editDate').val(btn.data('date'));
            $('#editMonth').val(btn.data('month'));
            $('#editYear').val(btn.data('year'));
            $('#editText').val(btn.data('text'));

            const photo = btn.data('photo');
            if (photo) {
                $('#currentPhotoContainer').html(`<img src="/photos/${photo}" style="width: 100px;">`);
            } else {
                $('#currentPhotoContainer').html('None');
            }
        });
    });
</script>