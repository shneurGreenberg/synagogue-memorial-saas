<div class="admin-page yahrzeit-page" data-synagogue-slug="{{synagogue.slug}}" data-copy-label="{{t 'yahrzeit_copy_message'}}" data-copied-label="{{t 'yahrzeit_copied'}}" data-send-label="{{t 'yahrzeit_send_contact'}}" data-date-label="{{t 'date_of_death'}}" data-delete-confirm="{{t 'are_you_sure'}}" data-no-bio-label="{{t 'person_card_no_biography'}}" data-platform-whatsapp="{{t 'contact_platform_whatsapp'}}" data-platform-telegram="{{t 'contact_platform_telegram'}}" data-platform-max="{{t 'contact_platform_max'}}" data-platform-sms="{{t 'contact_platform_sms'}}" data-platform-email="{{t 'contact_platform_email'}}">
    <header class="admin-page-header">
        <div>
            <h1>{{t 'yahrzeit_page'}}</h1>
            <p class="admin-subtitle">{{t 'yahrzeit_subtitle'}} · {{todayLabel}}</p>
        </div>
        <div class="header-actions">
            <a href="/admin/{{synagogue.slug}}/people" class="btn-admin btn-admin-secondary">{{t 'people'}}</a>
        </div>
    </header>

    {{#unless emailConfigured}}
    <div class="alert alert-warning" role="alert">
        {{t 'yahrzeit_email_help'}}
    </div>
    {{/unless}}

    {{#if entries.length}}
    <div class="yahrzeit-list">
        {{#each entries}}
        <article class="yahrzeit-card yahrzeit-card-clickable" id="person-{{this.id}}" data-person-id="{{this.id}}">
            <div class="yahrzeit-card-layout">
                <div class="yahrzeit-tile-preview yahrzeit-card-open" style="--primary-color: {{../synagogue.theme.primaryColor}}; --text-color: {{../synagogue.theme.textColor}}; --accent-color: {{../synagogue.theme.accentColor}};">
                    {{#if this.photoUrl}}
                    <img class="yahrzeit-tile-photo" src="{{this.photoUrl}}" alt="{{this.name}}">
                    {{else}}
                    <div class="yahrzeit-tile-photo yahrzeit-tile-placeholder">{{initials this.name}}</div>
                    {{/if}}
                    <div class="yahrzeit-tile-body">
                        <h2>{{this.name}}</h2>
                        {{#if this.gregorianDateLabel}}
                        <p>{{this.gregorianDateLabel}}{{#if this.hebrewDateLabel}} · {{this.hebrewDateLabel}}{{/if}}</p>
                        {{/if}}
                    </div>
                    <div class="yahrzeit-tile-candle" aria-hidden="true">🕯</div>
                </div>

                <div class="yahrzeit-details">
                    <div class="yahrzeit-contact-block">
                        <h3>{{t 'contact_section'}}</h3>
                        {{#if this.hasContactDetails}}
                        {{#if this.contact.phone}}
                        <p><strong>{{t 'contact_phone'}}:</strong> {{this.contact.phone}}</p>
                        {{/if}}
                        {{#if this.contact.email}}
                        <p><strong>{{t 'contact_email'}}:</strong> {{this.contact.email}}</p>
                        {{/if}}
                        {{#if this.contact.name}}
                        <p><strong>{{t 'contact_name'}}:</strong> {{this.contact.name}}</p>
                        {{/if}}
                        {{#if this.contact.platform}}
                        {{#if (or this.contact.phone this.contact.email)}}
                        <p><strong>{{t 'contact_platform'}}:</strong> {{this.contactPlatformLabel}}</p>
                        {{/if}}
                        {{/if}}
                        {{else}}
                        <p class="seed-notice">{{t 'yahrzeit_no_contact'}}</p>
                        {{/if}}
                    </div>

                    <div class="yahrzeit-message-block">
                        <h3>{{t 'yahrzeit_prepared_message'}}</h3>
                        <textarea class="form-control yahrzeit-message" rows="8" readonly>{{this.preparedMessage}}</textarea>
                        <div class="yahrzeit-actions">
                            <button type="button" class="btn-admin btn-admin-secondary yahrzeit-copy-btn btn-admin-with-icon" data-message="{{this.preparedMessage}}">
                                <svg class="btn-admin-inline-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/></svg>
                                {{t 'yahrzeit_copy_message'}}
                            </button>
                            {{#if this.contactLink}}
                            <a href="{{this.contactLink}}" class="btn-admin btn-admin-primary yahrzeit-send-btn btn-admin-with-icon" data-tile-url="/admin/{{../synagogue.slug}}/yahrzeit/tile/{{this.id}}.png" data-person-name="{{this.name}}" target="_blank" rel="noopener noreferrer">
                                <svg class="btn-admin-inline-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M2.01 21 23 12 2.01 3 2 10l15 2-15 2z"/></svg>
                                {{t 'yahrzeit_send_contact'}}
                            </a>
                            {{/if}}
                            <a href="{{this.boardCardUrl}}" class="btn-admin btn-admin-ghost btn-admin-with-icon" target="_blank" rel="noopener noreferrer">
                                <svg class="btn-admin-inline-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                                {{t 'yahrzeit_view_board'}}
                            </a>
                            <a href="/admin/{{../synagogue.slug}}/people?edit={{this.id}}" class="btn-admin btn-admin-secondary btn-admin-with-icon">
                                <svg class="btn-admin-inline-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1.003 1.003 0 0 0 0-1.42l-2.34-2.34a1.003 1.003 0 0 0-1.42 0l-1.83 1.83 3.75 3.75 1.84-1.82z"/></svg>
                                {{t 'edit'}}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </article>
        {{/each}}
    </div>
    {{else}}
    <div class="admin-empty-state">
        <p>{{t 'yahrzeit_empty'}}</p>
    </div>
    {{/if}}

    {{#if weekEntries.length}}
    <section class="yahrzeit-week-section">
        <header class="yahrzeit-week-header">
            <h2>{{t 'yahrzeit_week_missed_title'}}</h2>
            <p class="admin-subtitle">{{t 'yahrzeit_week_missed_subtitle'}}</p>
        </header>
        <div class="yahrzeit-list yahrzeit-list-week">
        {{#each weekEntries}}
        <article class="yahrzeit-card yahrzeit-card-clickable yahrzeit-card-week" id="person-week-{{this.id}}" data-person-id="{{this.id}}">
            <div class="yahrzeit-card-layout">
                <div class="yahrzeit-tile-preview yahrzeit-card-open" style="--primary-color: {{../synagogue.theme.primaryColor}}; --text-color: {{../synagogue.theme.textColor}}; --accent-color: {{../synagogue.theme.accentColor}};">
                    {{#if this.photoUrl}}
                    <img class="yahrzeit-tile-photo" src="{{this.photoUrl}}" alt="{{this.name}}">
                    {{else}}
                    <div class="yahrzeit-tile-photo yahrzeit-tile-placeholder">{{initials this.name}}</div>
                    {{/if}}
                    <div class="yahrzeit-tile-body">
                        <h2>{{this.name}}</h2>
                        {{#if this.gregorianDateLabel}}
                        <p>{{this.gregorianDateLabel}}{{#if this.hebrewDateLabel}} · {{this.hebrewDateLabel}}{{/if}}</p>
                        {{/if}}
                    </div>
                    <div class="yahrzeit-tile-candle" aria-hidden="true">🕯</div>
                </div>

                <div class="yahrzeit-details">
                    <div class="yahrzeit-contact-block">
                        <h3>{{t 'contact_section'}}</h3>
                        {{#if this.hasContactDetails}}
                        {{#if this.contact.phone}}
                        <p><strong>{{t 'contact_phone'}}:</strong> {{this.contact.phone}}</p>
                        {{/if}}
                        {{#if this.contact.email}}
                        <p><strong>{{t 'contact_email'}}:</strong> {{this.contact.email}}</p>
                        {{/if}}
                        {{#if this.contact.name}}
                        <p><strong>{{t 'contact_name'}}:</strong> {{this.contact.name}}</p>
                        {{/if}}
                        {{#if this.contact.platform}}
                        {{#if (or this.contact.phone this.contact.email)}}
                        <p><strong>{{t 'contact_platform'}}:</strong> {{this.contactPlatformLabel}}</p>
                        {{/if}}
                        {{/if}}
                        {{else}}
                        <p class="seed-notice">{{t 'yahrzeit_no_contact'}}</p>
                        {{/if}}
                    </div>

                    <div class="yahrzeit-message-block">
                        <h3>{{t 'yahrzeit_prepared_message'}}</h3>
                        <textarea class="form-control yahrzeit-message" rows="8" readonly>{{this.preparedMessage}}</textarea>
                        <div class="yahrzeit-actions">
                            <button type="button" class="btn-admin btn-admin-secondary yahrzeit-copy-btn btn-admin-with-icon" data-message="{{this.preparedMessage}}">
                                <svg class="btn-admin-inline-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/></svg>
                                {{t 'yahrzeit_copy_message'}}
                            </button>
                            {{#if this.contactLink}}
                            <a href="{{this.contactLink}}" class="btn-admin btn-admin-primary yahrzeit-send-btn btn-admin-with-icon" data-tile-url="/admin/{{../synagogue.slug}}/yahrzeit/tile/{{this.id}}.png" data-person-name="{{this.name}}" target="_blank" rel="noopener noreferrer">
                                <svg class="btn-admin-inline-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M2.01 21 23 12 2.01 3 2 10l15 2-15 2z"/></svg>
                                {{t 'yahrzeit_send_contact'}}
                            </a>
                            {{/if}}
                            <a href="{{this.boardCardUrl}}" class="btn-admin btn-admin-ghost btn-admin-with-icon" target="_blank" rel="noopener noreferrer">
                                <svg class="btn-admin-inline-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                                {{t 'yahrzeit_view_board'}}
                            </a>
                            <a href="/admin/{{../synagogue.slug}}/people?edit={{this.id}}" class="btn-admin btn-admin-secondary btn-admin-with-icon">
                                <svg class="btn-admin-inline-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1.003 1.003 0 0 0 0-1.42l-2.34-2.34a1.003 1.003 0 0 0-1.42 0l-1.83 1.83 3.75 3.75 1.84-1.82z"/></svg>
                                {{t 'edit'}}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </article>
        {{/each}}
        </div>
    </section>
    {{/if}}
</div>

<script id="yahrzeit-people-data" type="application/json">{{{json yahrzeitPeople}}}</script>
{{> admin-person-card-modal}}

<script src="/js/admin-yahrzeit.js"></script>
