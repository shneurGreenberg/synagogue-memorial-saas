<div class="admin-page users-page">
    <header class="admin-page-header">
        <div>
            <h1>{{t 'user_management'}}</h1>
            <p class="admin-subtitle">{{t 'user_management_subtitle'}}</p>
        </div>
        <div class="header-actions">
            <button type="button" class="btn-admin btn-admin-primary btn-admin-with-icon" data-toggle="modal" data-target="#addUserModal">
                {{{adminIcon 'add' class='btn-admin-inline-icon'}}}
                {{t 'add_user'}}
            </button>
        </div>
    </header>

    {{#if saved}}
    <div class="alert alert-success alert-dismissible fade show admin-alert" role="alert">
        {{t 'saved_settings'}}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {{/if}}

    {{#if error}}
    <div class="alert alert-danger alert-dismissible fade show admin-alert" role="alert">
        {{#if (eq error 'duplicate_username')}}{{t 'user_duplicate_error'}}{{else if (eq error 'missing_username')}}{{t 'user_missing_username'}}{{else}}{{t 'user_save_error'}}{{/if}}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {{/if}}

    <p class="seed-notice">{{t 'user_login_hint'}}</p>

    <div class="admin-panel">
        <div class="admin-panel-header">
            <h2>{{t 'current_users'}}</h2>
        </div>
        <div class="admin-panel-body">
            {{#if adminUsers.length}}
            <div class="table-responsive">
                <table class="table admin-table">
                    <thead>
                        <tr>
                            <th>{{t 'user_display_name'}}</th>
                            <th>{{t 'user_username'}}</th>
                            <th>{{t 'user_permissions'}}</th>
                            <th>{{t 'admin_language'}}</th>
                            <th>{{t 'color_mode'}}</th>
                            <th>{{t 'actions'}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each adminUsers}}
                        <tr>
                            <td>{{this.displayName}}</td>
                            <td><code>{{../synagogue.slug}}/{{this.username}}</code></td>
                            <td class="user-permissions-cell">
                                {{#if this.permissions.people}}{{t 'perm_people_short'}}{{/if}}
                                {{#if this.permissions.peopleImport}}{{#if this.permissions.people}}, {{/if}}{{t 'perm_people_import_short'}}{{/if}}
                                {{#if this.permissions.contactDirectory}}{{#if (or this.permissions.people this.permissions.peopleImport)}}, {{/if}}{{t 'perm_contact_directory_short'}}{{/if}}
                                {{#if this.permissions.events}}{{#if (or this.permissions.people this.permissions.peopleImport this.permissions.contactDirectory)}}, {{/if}}{{t 'perm_events_short'}}{{/if}}
                                {{#if this.permissions.settings}}
                                <div class="user-settings-perms">{{t 'settings_sections_label'}}:
                                    {{#if this.permissions.settingsPreview}}{{t 'perm_settings_preview_short'}}{{/if}}
                                    {{#if this.permissions.settingsAppearance}}{{#if this.permissions.settingsPreview}}, {{/if}}{{t 'perm_settings_appearance_short'}}{{/if}}
                                    {{#if this.permissions.settingsBranding}}{{#if (or this.permissions.settingsPreview this.permissions.settingsAppearance)}}, {{/if}}{{t 'perm_settings_branding_short'}}{{/if}}
                                    {{#if this.permissions.settingsFeatures}}{{#if (or this.permissions.settingsPreview this.permissions.settingsAppearance this.permissions.settingsBranding)}}, {{/if}}{{t 'perm_settings_features_short'}}{{/if}}
                                    {{#if this.permissions.settingsLanguages}}{{#if (or this.permissions.settingsPreview this.permissions.settingsAppearance this.permissions.settingsBranding this.permissions.settingsFeatures)}}, {{/if}}{{t 'perm_settings_languages_short'}}{{/if}}
                                    {{#if this.permissions.settingsSavedViews}}{{#if (or this.permissions.settingsPreview this.permissions.settingsAppearance this.permissions.settingsBranding this.permissions.settingsFeatures this.permissions.settingsLanguages)}}, {{/if}}{{t 'perm_settings_saved_views_short'}}{{/if}}
                                    {{#if this.permissions.settingsAdminPanel}}{{#if (or this.permissions.settingsPreview this.permissions.settingsAppearance this.permissions.settingsBranding this.permissions.settingsFeatures this.permissions.settingsLanguages this.permissions.settingsSavedViews)}}, {{/if}}{{t 'perm_settings_admin_panel_short'}}{{/if}}
                                </div>
                                {{/if}}
                            </td>
                            <td>{{this.adminLanguage}}</td>
                            <td>{{#if (eq this.adminColorMode 'light')}}{{t 'light_mode'}}{{else}}{{t 'dark_mode'}}{{/if}}</td>
                            <td>
                                <button type="button" class="btn-admin btn-admin-secondary btn-sm btn-admin-with-icon" data-toggle="modal"
                                    data-target="#editUserModal"
                                    data-user-id="{{this.id}}"
                                    data-username="{{this.username}}"
                                    data-display-name="{{this.displayName}}"
                                    data-admin-language="{{this.adminLanguage}}"
                                    data-color-mode="{{this.adminColorMode}}"
                                    data-perm-people="{{#if this.permissions.people}}1{{/if}}"
                                    data-perm-people-import="{{#if this.permissions.peopleImport}}1{{/if}}"
                                    data-perm-contact-directory="{{#if this.permissions.contactDirectory}}1{{/if}}"
                                    data-perm-events="{{#if this.permissions.events}}1{{/if}}"
                                    data-perm-settings-preview="{{#if this.permissions.settingsPreview}}1{{/if}}"
                                    data-perm-settings-appearance="{{#if this.permissions.settingsAppearance}}1{{/if}}"
                                    data-perm-settings-branding="{{#if this.permissions.settingsBranding}}1{{/if}}"
                                    data-perm-settings-features="{{#if this.permissions.settingsFeatures}}1{{/if}}"
                                    data-perm-settings-languages="{{#if this.permissions.settingsLanguages}}1{{/if}}"
                                    data-perm-settings-saved-views="{{#if this.permissions.settingsSavedViews}}1{{/if}}"
                                    data-perm-settings-admin-panel="{{#if this.permissions.settingsAdminPanel}}1{{/if}}">
                                    {{{adminIcon 'edit' class='btn-admin-inline-icon'}}}{{t 'edit'}}
                                </button>
                                <form method="POST" action="/admin/{{../synagogue.slug}}/users/delete" class="d-inline"
                                    onsubmit="return confirm('{{t 'are_you_sure'}}');">
                                    <input type="hidden" name="userId" value="{{this.id}}">
                                    <button type="submit" class="btn-admin btn-admin-danger btn-sm btn-admin-with-icon">{{{adminIcon 'delete' class='btn-admin-inline-icon'}}}{{t 'delete'}}</button>
                                </form>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{else}}
            <p class="text-muted mb-0">{{t 'no_users_yet'}}</p>
            {{/if}}
        </div>
    </div>
</div>

<div class="modal fade" id="addUserModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content admin-modal">
            <form method="POST" action="/admin/{{synagogue.slug}}/users/add">
                <div class="modal-header">
                    <h5 class="modal-title">{{t 'add_user'}}</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
                </div>
                <div class="modal-body">
                    {{> user-form-fields}}
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-admin btn-admin-secondary btn-admin-with-icon" data-dismiss="modal">{{{adminIcon 'cancel' class='btn-admin-inline-icon'}}}{{t 'cancel'}}</button>
                    <button type="submit" class="btn-admin btn-admin-primary btn-admin-with-icon">{{{adminIcon 'add' class='btn-admin-inline-icon'}}}{{t 'add'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editUserModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content admin-modal">
            <form method="POST" action="/admin/{{synagogue.slug}}/users/edit" id="editUserForm">
                <input type="hidden" name="userId" id="editUserId">
                <div class="modal-header">
                    <h5 class="modal-title">{{t 'edit_user'}}</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
                </div>
                <div class="modal-body">
                    {{> user-form-fields prefix="edit"}}
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-admin btn-admin-secondary btn-admin-with-icon" data-dismiss="modal">{{{adminIcon 'cancel' class='btn-admin-inline-icon'}}}{{t 'cancel'}}</button>
                    <button type="submit" class="btn-admin btn-admin-primary btn-admin-with-icon">{{{adminIcon 'save' class='btn-admin-inline-icon'}}}{{t 'save_changes'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>