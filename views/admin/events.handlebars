<div class="admin-page events-page">
    <header class="admin-page-header">
        <div>
            <h1>{{t 'community_events'}}</h1>
            <p class="admin-subtitle">{{t 'community_events_subtitle'}}</p>
        </div>
    </header>

    <div id="eventsStatusBanner" class="admin-alert events-status-banner events-status-banner--success" hidden aria-live="polite"></div>

    <section class="admin-panel">
        <div class="admin-panel-header">
            <h2>{{t 'add_community_event'}}</h2>
            <p class="admin-panel-desc">{{t 'community_events_add_help'}}</p>
        </div>
        <div class="admin-panel-body events-form-layout">
            <form method="POST" action="/admin/{{synagogue.slug}}/events/add" class="add-event-form events-editor-form" id="addEventForm">
                <div class="events-editor-fields">
                <div class="form-field">
                    <label for="eventTitleRu">{{t 'event_title'}} ({{t 'language_ru'}})</label>
                    <input type="text" name="titleRu" id="eventTitleRu" class="form-control admin-input-modern event-preview-input"
                        placeholder="{{t 'event_title_placeholder'}}">
                </div>
                <div class="form-field">
                    <label for="eventTitleEn">{{t 'event_title'}} ({{t 'language_en'}})</label>
                    <input type="text" name="titleEn" id="eventTitleEn" class="form-control admin-input-modern event-preview-input"
                        placeholder="{{t 'event_title_placeholder'}}">
                </div>
                <div class="form-field">
                    <label for="eventTextRu">{{t 'event_description_optional'}} ({{t 'language_ru'}})</label>
                    <textarea name="textRu" id="eventTextRu" class="form-control admin-input-modern event-preview-input" rows="2"
                        placeholder="{{t 'event_description_placeholder'}}"></textarea>
                </div>
                <div class="form-field">
                    <label for="eventTextEn">{{t 'event_description_optional'}} ({{t 'language_en'}})</label>
                    <textarea name="textEn" id="eventTextEn" class="form-control admin-input-modern event-preview-input" rows="2"
                        placeholder="{{t 'event_description_placeholder'}}"></textarea>
                </div>
                <div class="form-field">
                    <label>{{t 'event_date_label'}} <span class="field-optional">({{t 'optional'}})</span></label>
                    <div class="date-inputs-row">
                        <div class="date-input-group">
                            <label for="eventMonth" class="sr-only">{{t 'month'}}</label>
                            <input type="number" name="eventMonth" id="eventMonth" class="form-control admin-input-modern"
                                min="1" max="12" placeholder="{{t 'month'}}">
                        </div>
                        <div class="date-input-group">
                            <label for="eventDay" class="sr-only">{{t 'day'}}</label>
                            <input type="number" name="eventDate" id="eventDay" class="form-control admin-input-modern"
                                min="1" max="31" placeholder="{{t 'day'}}">
                        </div>
                        <div class="date-input-group">
                            <label for="eventYear" class="sr-only">{{t 'year'}}</label>
                            <input type="number" name="eventYear" id="eventYear" class="form-control admin-input-modern"
                                min="1900" max="2100" placeholder="{{t 'year'}}">
                        </div>
                    </div>
                    <span class="field-hint">{{t 'event_date_help'}}</span>
                </div>
                <div class="settings-two-col">
                    <div class="form-field">
                        <label for="eventStartAt">{{t 'event_start_at'}} <span class="field-optional">({{t 'optional'}})</span></label>
                        <input type="datetime-local" name="startAt" id="eventStartAt"
                            class="form-control admin-input-modern">
                        <span class="field-hint">{{t 'event_start_at_help'}}</span>
                    </div>
                    <div class="form-field">
                        <label for="eventEndAt">{{t 'event_end_at'}} <span class="field-optional">({{t 'optional'}})</span></label>
                        <input type="datetime-local" name="endAt" id="eventEndAt"
                            class="form-control admin-input-modern">
                        <span class="field-hint">{{t 'event_end_at_help'}}</span>
                    </div>
                </div>
                <div class="event-form-actions">
                    <button type="submit" class="btn-admin btn-admin-primary btn-admin-with-icon" data-publish-now="0">
                        {{{adminIcon 'schedule' class='btn-admin-inline-icon'}}}
                        {{t 'schedule_event'}}
                    </button>
                    <button type="submit" class="btn-admin btn-admin-accent btn-admin-with-icon" data-publish-now="1">
                        {{{adminIcon 'publish' class='btn-admin-inline-icon'}}}
                        {{t 'publish_now'}}
                    </button>
                </div>
                </div>

                <aside class="events-board-preview" id="eventsBoardPreview"
                    data-board-lang="{{synagogue.language}}"
                    style="--primary-color: {{synagogue.theme.primaryColor}}; --text-color: {{synagogue.theme.textColor}}; --accent-color: {{synagogue.theme.accentColor}};">
                    <h3 class="events-board-preview-title">{{t 'event_board_preview_title'}}</h3>
                    <p class="field-hint">{{t 'event_board_preview_help'}}</p>
                    <div class="events-board-preview-panel">
                        <h4 class="events-board-preview-section" id="eventsPreviewSectionTitle">{{t 'sidebar_upcoming_title'}}</h4>
                        <ul class="events-board-preview-list">
                            <li class="community-event-item events-board-preview-item">
                                <div class="community-event-link" role="note">
                                    <time id="eventsPreviewDate">{{t 'event_board_preview_date_sample'}}</time>
                                    <span class="community-event-title" id="eventsPreviewTitle">{{t 'event_board_preview_title_sample'}}</span>
                                    <span class="community-event-text" id="eventsPreviewText">{{t 'event_board_preview_text_sample'}}</span>
                                </div>
                            </li>
                        </ul>
                    </div>
                </aside>
            </form>
        </div>
    </section>

    <section class="admin-panel" id="activeEventsPanel">
        <div class="admin-panel-header">
            <h2>{{t 'active_events'}}</h2>
        </div>
        <div class="admin-panel-body">
            <div class="events-list" id="activeEventsList" data-section="active"></div>
        </div>
    </section>

    <section class="admin-panel" id="scheduledEventsPanel">
        <div class="admin-panel-header">
            <h2>{{t 'scheduled_events'}}</h2>
        </div>
        <div class="admin-panel-body">
            <div class="events-list" id="scheduledEventsList" data-section="scheduled"></div>
        </div>
    </section>

    <section class="admin-panel" id="historyEventsPanel">
        <div class="admin-panel-header">
            <h2>{{t 'events_history'}}</h2>
            <p class="admin-panel-desc">{{t 'events_history_help'}}</p>
        </div>
        <div class="admin-panel-body">
            <div class="events-list events-list-history" id="historyEventsList" data-section="history"></div>
        </div>
    </section>
</div>

<div class="modal fade admin-modal" id="editEventModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="POST" action="/admin/{{synagogue.slug}}/events/edit" id="editEventForm">
                <input type="hidden" name="eventId" id="editEventId">
                <div class="modal-header">
                    <h5 class="modal-title">{{t 'edit_event'}}</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-field">
                        <label for="editEventTitleRu">{{t 'event_title'}} ({{t 'language_ru'}})</label>
                        <input type="text" name="titleRu" id="editEventTitleRu" class="form-control admin-input-modern">
                    </div>
                    <div class="form-field">
                        <label for="editEventTitleEn">{{t 'event_title'}} ({{t 'language_en'}})</label>
                        <input type="text" name="titleEn" id="editEventTitleEn" class="form-control admin-input-modern">
                    </div>
                    <div class="form-field">
                        <label for="editEventTextRu">{{t 'event_description_optional'}} ({{t 'language_ru'}})</label>
                        <textarea name="textRu" id="editEventTextRu" class="form-control admin-input-modern" rows="2"></textarea>
                    </div>
                    <div class="form-field">
                        <label for="editEventTextEn">{{t 'event_description_optional'}} ({{t 'language_en'}})</label>
                        <textarea name="textEn" id="editEventTextEn" class="form-control admin-input-modern" rows="2"></textarea>
                    </div>
                    <div class="form-field">
                        <label>{{t 'event_date_label'}} <span class="field-optional">({{t 'optional'}})</span></label>
                        <div class="date-inputs-row">
                            <input type="number" name="eventMonth" id="editEventMonth" class="form-control admin-input-modern"
                                min="1" max="12" placeholder="{{t 'month'}}">
                            <input type="number" name="eventDate" id="editEventDay" class="form-control admin-input-modern"
                                min="1" max="31" placeholder="{{t 'day'}}">
                            <input type="number" name="eventYear" id="editEventYear" class="form-control admin-input-modern"
                                min="1900" max="2100" placeholder="{{t 'year'}}">
                        </div>
                    </div>
                    <div class="form-field">
                        <label for="editEventStartAt">{{t 'event_start_at'}}</label>
                        <input type="datetime-local" name="startAt" id="editEventStartAt"
                            class="form-control admin-input-modern">
                    </div>
                    <div class="form-field">
                        <label for="editEventEndAt">{{t 'event_end_at'}}</label>
                        <input type="datetime-local" name="endAt" id="editEventEndAt"
                            class="form-control admin-input-modern">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-admin btn-admin-ghost btn-admin-with-icon" data-dismiss="modal">{{{adminIcon 'cancel' class='btn-admin-inline-icon'}}}{{t 'cancel'}}</button>
                    <button type="submit" class="btn-admin btn-admin-primary btn-admin-with-icon">{{{adminIcon 'save' class='btn-admin-inline-icon'}}}{{t 'save_changes'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    window.eventsAdminLabels = {
        saving: '{{t 'saving'}}',
        saved: '{{t 'saved'}}',
        eventSaved: '{{t 'event_saved'}}',
        eventDeleted: '{{t 'event_deleted'}}',
        eventSaveFailed: '{{t 'event_save_failed'}}',
        areYouSure: '{{t 'are_you_sure'}}',
        edit: '{{t 'edit'}}',
        delete: '{{t 'delete'}}',
        publishNow: '{{t 'publish_now'}}',
        endNow: '{{t 'end_now'}}',
        noActiveEvents: '{{t 'no_active_events'}}',
        noScheduledEvents: '{{t 'no_scheduled_events'}}',
        noHistoryEvents: '{{t 'no_history_events'}}',
        eventStartAt: '{{t 'event_start_at'}}',
        eventEndAt: '{{t 'event_end_at'}}',
        eventStartRequired: '{{t 'event_start_required'}}',
        eventTitleRequired: '{{t 'event_title_required'}}',
        month: '{{t 'month'}}',
        day: '{{t 'day'}}',
        year: '{{t 'year'}}',
    };
    window.eventsAdminSlug = '{{synagogue.slug}}';
    window.eventsBoardLang = '{{synagogue.language}}';
    window.eventsPreviewLabels = {
        ru: {
            sectionTitle: '{{t 'sidebar_upcoming_title'}}',
            titleSample: '{{t 'event_board_preview_title_sample'}}',
            textSample: '{{t 'event_board_preview_text_sample'}}',
            dateSample: '{{t 'event_board_preview_date_sample'}}',
        },
        en: {
            sectionTitle: 'Upcoming dates & announcements',
            titleSample: 'Community event',
            textSample: 'Additional details for the announcement',
            dateSample: '15 March / 15 Adar',
        },
    };
</script>
<script id="events-data" type="application/json">{{{json events}}}</script>
