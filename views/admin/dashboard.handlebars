<div class="admin-page settings-page">
    <header class="admin-page-header">
        <div>
            <h1>{{t 'settings'}}</h1>
            <p class="admin-subtitle">{{t 'settings_subtitle'}}</p>
        </div>
    </header>

  {{#if error}}
    <div class="alert alert-danger alert-dismissible fade show admin-alert" role="alert">
        {{#if (eq error 'upload')}}{{t 'upload_error'}}{{else}}{{error}}{{/if}}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
  {{/if}}

  {{#if saved}}
    <div class="alert alert-success alert-dismissible fade show admin-alert" role="alert">
        {{t 'saved_settings'}}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
  {{/if}}

    <form method="POST" action="/admin/{{synagogue.slug}}/settings" enctype="multipart/form-data" class="settings-form" id="settingsForm" data-save-label="{{t 'save'}}" data-slug="{{synagogue.slug}}">
        {{#if adminPermissions.settingsPreview}}
        <section class="admin-panel settings-preview-panel admin-panel-collapsible is-expanded">
            <button type="button" class="admin-panel-header admin-panel-toggle" aria-expanded="true">
                <h2 class="admin-panel-title">
                    <svg class="admin-panel-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M21 3H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h5v2h8v-2h5c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2m0 14H3V5h18v12Z"/></svg>
                    {{t 'live_preview'}}
                    {{#if activeSavedViewName}}
                    <span class="active-saved-view-badge" id="activeSavedViewBadge">{{activeSavedViewName}}</span>
                    {{else}}
                    <span class="active-saved-view-badge" id="activeSavedViewBadge" hidden></span>
                    {{/if}}
                </h2>
                <span class="admin-panel-chevron" aria-hidden="true"></span>
            </button>
            <div class="admin-panel-body">
                <div class="board-preview-stage" id="boardPreviewStage">
                    <div class="board-preview-frame-wrap" id="boardPreviewWrap">
                        {{#if activeSavedViewName}}
                        <span class="board-preview-view-badge" id="boardPreviewViewBadge">{{activeSavedViewName}}</span>
                        {{else}}
                        <span class="board-preview-view-badge" id="boardPreviewViewBadge" hidden></span>
                        {{/if}}
                        <iframe id="boardPreviewFrame" class="board-preview-frame" title="{{t 'live_preview'}}"
                            src="/s/{{synagogue.slug}}"></iframe>
                    </div>
                </div>
                <p class="preview-hint">{{t 'live_preview_help'}}</p>
            </div>
        </section>
        {{/if}}

        {{#if (and (or adminPermissions.settingsAppearance adminPermissions.settingsPreview) adminPermissions.settingsSavedViews)}}
        <section class="admin-panel saved-views-panel admin-panel-collapsible is-collapsed">
            <button type="button" class="admin-panel-header admin-panel-toggle" aria-expanded="false">
                <h2 class="admin-panel-title">
                    <svg class="admin-panel-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M17 3H7c-1.1 0-2 .9-2 2v16l7-3 7 3V5c0-1.1-.9-2-2-2z"/></svg>
                    {{t 'saved_views_section'}}
                </h2>
                <span class="admin-panel-chevron" aria-hidden="true"></span>
            </button>
            <div class="admin-panel-body" hidden>
                {{#if (or adminPermissions.settingsAppearance adminPermissions.settingsPreview adminPermissions.settingsSavedViews)}}
                <div class="saved-view-actions">
                    {{#if adminPermissions.settingsSavedViews}}
                    <button type="button" class="btn-admin btn-admin-secondary" id="saveCurrentViewBtn">
                        <svg class="btn-admin-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4m-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3m3-10H5V5h10v4Z"/></svg>
                        {{t 'save_current_view'}}
                    </button>
                    <button type="button" class="btn-admin btn-admin-primary" id="updateCurrentViewBtn" {{#unless activeSavedViewId}}disabled{{/unless}}>
                        <svg class="btn-admin-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M21 7.5V19c0 1.1-.9 2-2 2H5c-1.1 0-2-.9-2-2V5c0-1.1.9-2 2-2h9.5L21 7.5M12 18v-6h3l-4-4-4 4h3v6h2Z"/></svg>
                        {{t 'update_current_view'}}
                    </button>
                    {{/if}}
                    {{#if adminPermissions.settingsAppearance}}
                    <button type="button" class="btn-admin btn-admin-secondary reset-theme-btn" id="resetThemeBtn">
                        <svg class="btn-admin-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/></svg>
                        {{t 'reset_theme'}}
                    </button>
                    {{/if}}
                </div>
                {{#if adminPermissions.settingsAppearance}}
                <p class="field-hint">{{t 'reset_theme_help'}}</p>
                {{/if}}
                {{/if}}
                <p class="field-hint">{{t 'saved_views_help'}}</p>
                <div class="saved-views-grid" id="savedViewsGrid"
                    data-slug="{{synagogue.slug}}"
                    data-delete-confirm="{{t 'saved_view_delete_confirm'}}"
                    data-empty-text="{{t 'saved_views_empty'}}"
                    data-apply-error="{{t 'saved_view_apply_error'}}"
                    data-delete-error="{{t 'saved_view_delete_error'}}">
                    {{#if savedViews.length}}
                        {{#each savedViews}}
                        <article class="saved-view-card{{#if (eq ../activeSavedViewId this.id)}} is-active{{/if}}" data-view-id="{{this.id}}">
                            <div class="saved-view-thumb">
                                {{#if this.screenshot}}
                                <img src="/images/{{this.screenshot}}" alt="{{this.name}}">
                                {{else}}
                                <div class="saved-view-thumb-empty">{{t 'no_photo'}}</div>
                                {{/if}}
                                <span class="saved-view-thumb-label">{{this.name}}</span>
                            </div>
                            <div class="saved-view-meta">
                                <h3>{{this.name}}</h3>
                                <time datetime="{{this.savedAt}}">{{this.savedAt}}</time>
                            </div>
                            <div class="saved-view-card-actions">
                                <button type="button" class="btn-admin btn-admin-secondary saved-view-apply-btn">
                                    <svg class="btn-admin-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M9 16.17 4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17Z"/></svg>
                                    {{t 'saved_view_apply'}}
                                </button>
                                <button type="button" class="btn-admin btn-admin-danger saved-view-delete-btn">
                                    <svg class="btn-admin-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12M19 4h-3.5l-1-1h-5l-1 1H5v2h14V4Z"/></svg>
                                    {{t 'saved_view_delete'}}
                                </button>
                            </div>
                        </article>
                        {{/each}}
                    {{else}}
                        <p class="saved-views-empty" id="savedViewsEmpty">{{t 'saved_views_empty'}}</p>
                    {{/if}}
                </div>
            </div>
        </section>
        {{/if}}

        {{#if adminPermissions.settingsAppearance}}
        <section class="admin-panel admin-panel-collapsible is-collapsed">
            <button type="button" class="admin-panel-header admin-panel-toggle" aria-expanded="false">
                <h2 class="admin-panel-title">
                    <svg class="admin-panel-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9c.83 0 1.5-.67 1.5-1.5 0-.39-.15-.74-.39-1.01-.23-.26-.38-.61-.38-.99 0-.83.67-1.5 1.5-1.5H16c2.76 0 5-2.24 5-5 0-4.42-4.03-8-9-8m-5.5 9a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m3-4a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m7 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m3 4a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3"/></svg>
                    {{t 'appearance_section'}}
                </h2>
                <span class="admin-panel-chevron" aria-hidden="true"></span>
            </button>
            <div class="admin-panel-body" hidden>
                {{#if (or adminPermissions.settingsAppearance adminPermissions.settingsAdminPanel)}}
                <div class="admin-theme-setting color-mode-field settings-appearance-row"
                    data-light-label="{{t 'light_mode'}}"
                    data-dark-label="{{t 'dark_mode'}}">
                    <div class="admin-theme-setting-label">{{t 'admin_panel_appearance'}}</div>
                    <input type="hidden" name="colorMode" id="colorModeInput"
                        value="{{#if (eq synagogue.adminColorMode 'light')}}light{{else}}dark{{/if}}">
                    <div class="admin-theme-setting-control">
                        <label class="toggle-switch color-mode-toggle" for="colorModeToggle">
                            <input type="checkbox" id="colorModeToggle"
                                {{#if (eq synagogue.adminColorMode 'light')}}checked{{/if}}>
                            <span class="toggle-slider" aria-hidden="true"></span>
                        </label>
                        <span class="toggle-mode-text" id="colorModeToggleLabel">
                            {{#if (eq synagogue.adminColorMode 'light')}}{{t 'light_mode'}}{{else}}{{t 'dark_mode'}}{{/if}}
                        </span>
                    </div>
                    <p class="field-hint admin-theme-setting-hint">{{t 'color_mode_help'}}</p>
                </div>
                {{/if}}
                <div class="colors-controls">
                    <h3 class="typography-controls-title">{{t 'colors_section'}}</h3>
                    <div class="color-picker-row color-picker-modern">
                        <div class="color-field-modern">
                            <label for="primaryColor">{{t 'primary_color'}}</label>
                            <div class="color-swatch-row">
                                <input type="color" name="primaryColor" id="primaryColor" class="color-swatch-input"
                                    value="{{synagogue.theme.primaryColor}}">
                                <input type="text" class="color-hex-display" id="primaryColorHex" readonly
                                    value="{{synagogue.theme.primaryColor}}">
                            </div>
                            <span class="field-hint">{{t 'primary_color_help'}}</span>
                        </div>
                        <div class="color-field-modern">
                            <label for="textColor">{{t 'text_color'}}</label>
                            <div class="color-swatch-row">
                                <input type="color" name="textColor" id="textColor" class="color-swatch-input"
                                    value="{{synagogue.theme.textColor}}">
                                <input type="text" class="color-hex-display" id="textColorHex" readonly
                                    value="{{synagogue.theme.textColor}}">
                            </div>
                            <span class="field-hint">{{t 'text_color_help'}}</span>
                        </div>
                        <div class="color-field-modern">
                            <label for="accentColor">{{t 'accent_color'}}</label>
                            <div class="color-swatch-row">
                                <input type="color" name="accentColor" id="accentColor" class="color-swatch-input"
                                    value="{{synagogue.theme.accentColor}}">
                                <input type="text" class="color-hex-display" id="accentColorHex" readonly
                                    value="{{synagogue.theme.accentColor}}">
                            </div>
                            <span class="field-hint">{{t 'accent_color_help'}}</span>
                        </div>
                        <div class="color-field-modern">
                            <label for="tileColor">{{t 'tile_color'}}</label>
                            <div class="color-swatch-row">
                                <input type="color" name="tileColor" id="tileColor" class="color-swatch-input"
                                    value="{{synagogue.theme.tileColor}}">
                                <input type="text" class="color-hex-display" id="tileColorHex" readonly
                                    value="{{synagogue.theme.tileColor}}">
                            </div>
                            <span class="field-hint">{{t 'tile_color_help'}}</span>
                        </div>
                    </div>
                    <div class="slider-field-modern">
                        <label for="tileOpacity">{{t 'tile_opacity'}}</label>
                        <div class="slider-row">
                            <input type="range" name="tileOpacity" id="tileOpacity" class="admin-range-input"
                                min="0" max="100" step="1"
                                value="{{#if synagogue.theme.tileOpacity}}{{synagogue.theme.tileOpacity}}{{else}}100{{/if}}">
                            <output class="slider-value-display" id="tileOpacityValue">{{#if synagogue.theme.tileOpacity}}{{synagogue.theme.tileOpacity}}{{else}}100{{/if}}%</output>
                        </div>
                        <span class="field-hint">{{t 'tile_opacity_help'}}</span>
                    </div>
                </div>
                <div class="appearance-subsections">
                    <h3 class="typography-controls-title">{{t 'backgrounds_section'}}</h3>
                    <div class="branding-subsections">
                        <section class="admin-panel admin-panel-collapsible branding-subsection is-collapsed">
                            <button type="button" class="admin-panel-header admin-panel-toggle" aria-expanded="false">
                                <h4 class="admin-panel-title">
                                    <svg class="admin-panel-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M4 4h7V2H4c-1.1 0-2 .9-2 2v7h2V4m6 0v2h7v7h2V6c0-1.1-.9-2-2-2h-7M4 14v7h7v2H4c-1.1 0-2-.9-2-2v-7h2m12 2h-2v7h-7v2h7c1.1 0 2-.9 2-2v-7h2v-2z"/></svg>
                                    {{t 'background_image'}}
                                </h4>
                                <span class="admin-panel-chevron" aria-hidden="true"></span>
                            </button>
                            <div class="admin-panel-body" hidden>
                                <div class="media-upload-card media-upload-card-flat">
                                    <p class="field-hint">{{t 'background_image_help'}}</p>
                                    <div class="media-preview">
                                        {{#if synagogue.theme.backgroundImage}}
                                        <img src="/images/{{synagogue.theme.backgroundImage}}" alt="{{t 'background_image'}}">
                                        {{else}}
                                        <img src="/images/brickwall.jpg" alt="{{t 'background_image'}}">
                                        {{/if}}
                                    </div>
                                    <label class="file-drop-label">
                                        {{t 'replace_image'}}
                                        <input type="file" name="backgroundImage" accept="image/*">
                                    </label>
                                </div>
                            </div>
                        </section>
                        <section class="admin-panel admin-panel-collapsible branding-subsection is-collapsed">
                            <button type="button" class="admin-panel-header admin-panel-toggle" aria-expanded="false">
                                <h4 class="admin-panel-title">
                                    <svg class="admin-panel-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M3 3h8v8H3V3m10 0h8v5h-8V3M3 13h5v8H3v-8m7 4h11v4H10v-4Z"/></svg>
                                    {{t 'tiles_background'}}
                                </h4>
                                <span class="admin-panel-chevron" aria-hidden="true"></span>
                            </button>
                            <div class="admin-panel-body" hidden>
                                <div class="media-upload-card media-upload-card-flat">
                                    <p class="field-hint">{{t 'tiles_background_help'}}</p>
                                    <div class="media-preview">
                                        {{#if synagogue.theme.tilesBackground}}
                                        <img src="/images/{{synagogue.theme.tilesBackground}}" alt="{{t 'tiles_background'}}">
                                        {{else}}
                                        <img src="/images/wood2.png" alt="{{t 'tiles_background'}}">
                                        {{/if}}
                                    </div>
                                    <label class="file-drop-label">
                                        {{t 'replace_image'}}
                                        <input type="file" name="tilesBackground" accept="image/*">
                                    </label>
                                </div>
                            </div>
                        </section>
                    </div>
                    <h3 class="typography-controls-title">{{t 'candle_appearance_section'}}</h3>
                    <div class="board-features-grid">
                        <div class="form-field candle-palette-field admin-theme-setting admin-theme-setting-wide">
                            <label for="candlePalette">{{t 'candle_palette'}}</label>
                            <select name="candlePalette" id="candlePalette" class="form-control admin-select-modern">
                                {{#each candlePaletteOptions}}
                                <option value="{{this.key}}" {{#if (eq ../synagogue.theme.candlePalette this.key)}}selected{{else}}{{#unless ../synagogue.theme.candlePalette}}{{#if (eq this.key 'classic')}}selected{{/if}}{{/unless}}{{/if}}>{{t this.labelKey}}</option>
                                {{/each}}
                            </select>
                            <p class="field-hint admin-theme-setting-hint">{{t 'candle_palette_help'}}</p>
                        </div>
                        <div class="slider-field-modern admin-theme-setting admin-theme-setting-wide">
                            <label for="fontScale_candle">{{t candleSlider.labelKey}}</label>
                            <div class="slider-row">
                                <input type="range" name="fontScale_candle" id="fontScale_candle"
                                    class="admin-range-input font-scale-input" data-font-scale-key="candle"
                                    min="{{#if candleSlider.min}}{{candleSlider.min}}{{else}}40{{/if}}"
                                    max="{{#if candleSlider.max}}{{candleSlider.max}}{{else}}150{{/if}}"
                                    step="{{#if candleSlider.step}}{{candleSlider.step}}{{else}}5{{/if}}"
                                    value="{{candleSlider.value}}">
                                <output class="slider-value-display font-scale-value" data-for="fontScale_candle">{{candleSlider.value}}%</output>
                            </div>
                            <p class="field-hint admin-theme-setting-hint">{{t candleSlider.helpKey}}</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="admin-panel admin-panel-collapsible is-collapsed">
            <button type="button" class="admin-panel-header admin-panel-toggle" aria-expanded="false">
                <h2 class="admin-panel-title">
                    <svg class="admin-panel-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M5 4v3h5.5v12h3V7H19V4H5z"/></svg>
                    {{t 'texts_section'}}
                </h2>
                <span class="admin-panel-chevron" aria-hidden="true"></span>
            </button>
            <div class="admin-panel-body" hidden>
                <div class="board-titles-grid">
                    <div class="form-field">
                        <label for="titleRu">{{t 'board_title_ru'}}</label>
                        <input type="text" name="titleRu" id="titleRu" class="form-control admin-input-modern"
                            value="{{boardTitles.ru}}">
                    </div>
                    <div class="form-field">
                        <label for="titleEn">{{t 'board_title_en'}}</label>
                        <input type="text" name="titleEn" id="titleEn" class="form-control admin-input-modern"
                            value="{{boardTitles.en}}">
                    </div>
                    <div class="form-field">
                        <label for="titleHe">{{t 'board_title_he'}}</label>
                        <input type="text" name="titleHe" id="titleHe" class="form-control admin-input-modern"
                            value="{{boardTitles.he}}">
                    </div>
                </div>
                <div class="typography-controls">
                    {{#each textsFontScaleGroups}}
                    <div class="typography-group">
                        <h3 class="typography-controls-title">
                            {{#if (eq this.groupKey 'typography_left_column')}}
                            <svg class="typography-controls-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M3 5v14c0 1.1.9 2 2 2h5V3H5c-1.1 0-2 .9-2 2m12-2h-5v18h5c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2"/></svg>
                            {{/if}}
                            {{#if (eq this.groupKey 'typography_center_column')}}
                            <svg class="typography-controls-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M4 6h16v2H4V6m0 5h16v2H4v-2m0 5h16v2H4v-2Z"/></svg>
                            {{/if}}
                            {{#if (eq this.groupKey 'typography_right_column')}}
                            <svg class="typography-controls-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M19 5v14c0 1.1-.9 2-2 2h-5V3h5c1.1 0 2 .9 2 2m-12 0H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h2V5Z"/></svg>
                            {{/if}}
                            {{t this.groupKey}}
                        </h3>
                        <p class="field-hint">{{t this.helpKey}}</p>
                        <div class="font-scale-grid">
                            {{#each this.sliders}}
                            <div class="slider-field-modern">
                                <label for="fontScale_{{this.key}}">{{t this.labelKey}}</label>
                                <div class="slider-row">
                                    <input type="range" name="fontScale_{{this.key}}" id="fontScale_{{this.key}}"
                                        class="admin-range-input font-scale-input" data-font-scale-key="{{this.key}}"
                                        min="{{#if this.min}}{{this.min}}{{else}}50{{/if}}" max="{{#if this.max}}{{this.max}}{{else}}200{{/if}}" step="{{#if this.step}}{{this.step}}{{else}}5{{/if}}" value="{{this.value}}">
                                    <output class="slider-value-display font-scale-value" data-for="fontScale_{{this.key}}">{{this.value}}%</output>
                                </div>
                                <span class="field-hint">{{t this.helpKey}}</span>
                            </div>
                            {{/each}}
                        </div>
                    </div>
                    {{/each}}
                </div>
            </div>
        </section>
        {{/if}}

        {{#if (or adminPermissions.settingsBranding adminPermissions.settingsAppearance)}}
        <section class="admin-panel admin-panel-collapsible is-collapsed">
            <button type="button" class="admin-panel-header admin-panel-toggle" aria-expanded="false">
                <h2 class="admin-panel-title">
                    <svg class="admin-panel-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3m-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3m0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5m8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5Z"/></svg>
                    {{t 'community_section'}}
                </h2>
                <span class="admin-panel-chevron" aria-hidden="true"></span>
            </button>
            <div class="admin-panel-body" hidden>
                {{#if adminPermissions.settingsBranding}}
                <div class="community-logo-settings">
                    <h3 class="typography-controls-title">{{t 'logo'}}</h3>
                    <div class="media-upload-card media-upload-card-flat">
                        <div class="media-preview media-preview-logo" id="communityLogoPreview"
                            style="--preview-logo-radius: {{#if synagogue.theme.logoBorderRadius}}{{synagogue.theme.logoBorderRadius}}{{else}}100{{/if}};">
                            {{#if synagogue.theme.logo}}
                            <img src="/images/{{synagogue.theme.logo}}" alt="{{t 'logo'}}" id="communityLogoPreviewImg">
                            {{else}}
                            <span class="media-preview-empty">{{t 'no_photo'}}</span>
                            {{/if}}
                        </div>
                        <label class="file-drop-label">
                            {{t 'replace_image'}}
                            <input type="file" name="logo" accept="image/*">
                        </label>
                    </div>
                    <div class="slider-field-modern">
                        <label for="logoBorderRadius">{{t 'logo_border_radius'}}</label>
                        <div class="slider-row">
                            <input type="range" name="logoBorderRadius" id="logoBorderRadius" class="admin-range-input logo-radius-input"
                                min="0" max="100" step="1"
                                value="{{#if synagogue.theme.logoBorderRadius}}{{synagogue.theme.logoBorderRadius}}{{else}}100{{/if}}">
                            <output class="slider-value-display" id="logoBorderRadiusValue">{{#if synagogue.theme.logoBorderRadius}}{{synagogue.theme.logoBorderRadius}}{{else}}100{{/if}}%</output>
                        </div>
                        <span class="field-hint">{{t 'logo_border_radius_help'}}</span>
                    </div>
                </div>
                {{/if}}
                {{#if adminPermissions.settingsAppearance}}
                {{> admin-settings-qr-codes}}
                {{/if}}
            </div>
        </section>
        {{/if}}

        {{#if adminPermissions.settingsFeatures}}
        <section class="admin-panel admin-panel-collapsible is-collapsed">
            <button type="button" class="admin-panel-header admin-panel-toggle" aria-expanded="false">
                <h2 class="admin-panel-title">
                    <svg class="admin-panel-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M4 6h16v2H4V6m0 5h16v2H4v-2m0 5h16v2H4v-2Z"/></svg>
                    {{t 'board_features_section'}}
                </h2>
                <span class="admin-panel-chevron" aria-hidden="true"></span>
            </button>
            <div class="admin-panel-body board-features-layout" hidden>
                {{#if yahrzeitTodayCount}}
                <p class="public-submission-yahrzeit-notice">{{t 'public_submission_yahrzeit_alert'}}</p>
                {{/if}}
                {{#each boardFeatureGroups}}
                <div class="board-features-group">
                    <h3 class="board-features-group-title">{{t this.groupKey}}</h3>
                    <p class="field-hint">{{t this.helpKey}}</p>
                    <div class="board-features-grid">
                        {{#if (eq this.special 'candle')}}
                        <div class="admin-theme-setting shabbat-times-setting">
                            <div class="admin-theme-setting-label">{{t 'enable_shabbat_times'}}</div>
                            <div class="admin-theme-setting-control">
                                <label class="toggle-switch" for="shabbatTimesEnabled">
                                    <input type="checkbox" id="shabbatTimesEnabled" name="shabbatTimesEnabled" value="1" {{#if ../synagogue.shabbatTimesEnabled}}checked{{/if}}>
                                    <span class="toggle-slider" aria-hidden="true"></span>
                                </label>
                            </div>
                            <p class="field-hint admin-theme-setting-hint">{{t 'enable_shabbat_times_help'}}</p>
                        </div>
                        {{/if}}
                        {{#if (eq this.special 'publicSubmission')}}
                        <div class="admin-theme-setting">
                            <div class="admin-theme-setting-label">{{t 'public_submission_enabled'}}</div>
                            <div class="admin-theme-setting-control">
                                <label class="toggle-switch" for="publicSubmissionEnabled">
                                    <input type="checkbox" id="publicSubmissionEnabled" name="publicSubmissionEnabled" value="1" {{#if ../synagogue.publicSubmission.enabled}}checked{{/if}}>
                                    <span class="toggle-slider" aria-hidden="true"></span>
                                </label>
                            </div>
                            <p class="field-hint admin-theme-setting-hint">{{t 'public_submission_enabled_help'}}</p>
                        </div>
                        <div class="form-field admin-theme-setting admin-theme-setting-wide">
                            <label>{{t 'public_submission_url_hint'}}</label>
                            <p class="admin-copy-link"><code>/s/{{../synagogue.slug}}/add-name</code></p>
                        </div>
                        {{/if}}
                        {{#each this.toggles}}
                        <div class="admin-theme-setting">
                            <div class="admin-theme-setting-label">{{t this.labelKey}}</div>
                            <div class="admin-theme-setting-control">
                                <label class="toggle-switch" for="feature_{{this.key}}">
                                    <input type="checkbox" id="feature_{{this.key}}" name="feature_{{this.key}}" value="1" {{#if this.enabled}}checked{{/if}}>
                                    <span class="toggle-slider" aria-hidden="true"></span>
                                </label>
                            </div>
                            <p class="field-hint admin-theme-setting-hint">{{t this.helpKey}}</p>
                        </div>
                        {{/each}}
                    </div>
                </div>
                {{/each}}
            </div>
        </section>
        {{/if}}

        {{#if (or adminPermissions.settingsLanguages adminPermissions.settingsAdminPanel)}}
        <section class="admin-panel admin-panel-collapsible is-collapsed">
            <button type="button" class="admin-panel-header admin-panel-toggle" aria-expanded="false">
                <h2 class="admin-panel-title">
                    <svg class="admin-panel-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12.87 15.07l-2.54-2.51.03-.03c1.74-1.94 2.98-4.17 3.71-6.53H17V4h-7V2H8v2H1v2h11.17C11.5 7.92 10.44 9.75 9 11.35 8.07 10.32 7.3 9.19 6.69 8h-2v2c.73 1.63 1.73 3.17 2.98 4.56l-5.09 5.02L4 19l5-5 3.11 3.11.76-2.04zM18.5 10h-2L12 22h2l1.12-3h4.75L21 22h2l-4.5-12z"/></svg>
                    {{t 'languages_section'}}
                </h2>
                <span class="admin-panel-chevron" aria-hidden="true"></span>
            </button>
            <div class="admin-panel-body" hidden>
                <div class="form-field">
                    <label for="language">{{t 'language'}}</label>
                    <select name="language" id="language" class="form-control admin-select-modern">
                        <option value="ru" {{#if (eq synagogue.language 'ru')}}selected{{/if}}>Russian</option>
                        <option value="en" {{#if (eq synagogue.language 'en')}}selected{{/if}}>English</option>
                        <option value="he" {{#if (eq synagogue.language 'he')}}selected{{/if}}>Hebrew</option>
                    </select>
                </div>
                {{#if (or adminPermissions.settingsAdminPanel adminPermissions.settingsLanguages)}}
                <div class="form-field">
                    <label for="adminLanguage">{{t 'admin_language'}}</label>
                    <select name="adminLanguage" id="adminLanguage" class="form-control admin-select-modern">
                        <option value="ru" {{#if (eq synagogue.adminLanguage 'ru')}}selected{{/if}}>Russian</option>
                        <option value="en" {{#if (eq synagogue.adminLanguage 'en')}}selected{{/if}}>English</option>
                        <option value="he" {{#if (eq synagogue.adminLanguage 'he')}}selected{{/if}}>Hebrew</option>
                    </select>
                </div>
                {{/if}}
            </div>
        </section>
        {{/if}}

        {{#if canSaveBoardSettings}}
        <div class="form-actions-sticky">
            <button type="submit" class="btn-admin btn-admin-primary btn-admin-with-icon">{{{adminIcon 'save'}}}{{t 'save'}}</button>
        </div>
        {{/if}}
    </form>

    <form method="POST" action="/admin/{{synagogue.slug}}/settings/reset-theme" id="resetThemeForm" class="visually-hidden-reset-form" aria-hidden="true"></form>
</div>

<script src="/js/admin-settings-panel.js"></script>
<script>
    (function () {
        var settingsForm = document.getElementById('settingsForm');
        var slug = (settingsForm && settingsForm.dataset.slug) || '{{synagogue.slug}}';

        function savePersonalPreferences(reloadPage) {
            var adminLanguage = document.getElementById('adminLanguage');
            var colorModeInput = document.getElementById('colorModeInput');
            if (!adminLanguage || !colorModeInput) {
                return Promise.resolve();
            }

            return fetch('/admin/' + slug + '/my-preferences', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest',
                },
                body: new URLSearchParams({
                    adminLanguage: adminLanguage.value,
                    colorMode: colorModeInput.value,
                }).toString(),
            }).then(function (response) {
                return response.json();
            }).then(function (data) {
                if (data && data.ok && reloadPage) {
                    window.location.reload();
                }
            }).catch(function () { /* ignore */ });
        }

        var TV_PREVIEW_W = 1920;
        var TV_PREVIEW_H = 1080;

        function fitBoardPreviewTv() {
            var wrap = document.getElementById('boardPreviewWrap');
            var frame = document.getElementById('boardPreviewFrame');
            if (!wrap || !frame) return;
            var w = wrap.clientWidth;
            var h = wrap.clientHeight;
            if (w < 1 || h < 1) return;
            var scale = Math.min(w / TV_PREVIEW_W, h / TV_PREVIEW_H);
            frame.style.setProperty('--board-preview-scale', String(scale));
        }

        window.addEventListener('resize', fitBoardPreviewTv);
        if (typeof ResizeObserver !== 'undefined') {
            var previewWrap = document.getElementById('boardPreviewWrap');
            if (previewWrap) {
                new ResizeObserver(fitBoardPreviewTv).observe(previewWrap);
            }
        }
        var previewDebounce;
        var PREVIEW_MESSAGE = 'board-preview';

        function readFontScalePatch() {
            var patch = {};
            document.querySelectorAll('.font-scale-input').forEach(function (input) {
                if (input.dataset.fontScaleKey) {
                    patch['fontScale_' + input.dataset.fontScaleKey] = input.value;
                }
            });
            return patch;
        }

        function readMemorialQrPatch() {
            function value(id) {
                var el = document.getElementById(id);
                return el ? el.value : '';
            }

            return {
                memorialQrTitleScale: value('memorialQrTitleScale'),
                memorialQrTextScale: value('memorialQrTextScale'),
                memorialQrQrScale: value('memorialQrQrScale'),
            };
        }

        function readPreviewPatch() {
            var primary = document.getElementById('primaryColor');
            var text = document.getElementById('textColor');
            var accent = document.getElementById('accentColor');
            var tile = document.getElementById('tileColor');
            var tileOpacity = document.getElementById('tileOpacity');
            var titleRu = document.getElementById('titleRu');
            var titleEn = document.getElementById('titleEn');
            var titleHe = document.getElementById('titleHe');
            var languageSelect = document.getElementById('language');

            return Object.assign({
                type: PREVIEW_MESSAGE,
                titleRu: titleRu ? titleRu.value.trim() : '',
                titleEn: titleEn ? titleEn.value.trim() : '',
                titleHe: titleHe ? titleHe.value.trim() : '',
                primaryColor: primary ? primary.value : '',
                textColor: text ? text.value : '',
                accentColor: accent ? accent.value : '',
                tileColor: tile ? tile.value : '',
                tileOpacity: tileOpacity ? tileOpacity.value : '100',
                candlePalette: (function () {
                    var el = document.getElementById('candlePalette');
                    return el ? el.value : 'classic';
                })(),
                logoBorderRadius: (function () {
                    var el = document.getElementById('logoBorderRadius');
                    return el ? el.value : '100';
                })(),
                previewLang: languageSelect ? languageSelect.value : 'ru',
            }, readFontScalePatch(), readMemorialQrPatch());
        }

        function bindColorPair(colorInputId, hexInputId) {
            var colorInput = document.getElementById(colorInputId);
            var hexInput = document.getElementById(hexInputId);
            if (!colorInput || !hexInput) return;

            colorInput.addEventListener('input', function () {
                hexInput.value = colorInput.value;
                schedulePreview();
            });
            colorInput.addEventListener('change', schedulePreview);
        }

        bindColorPair('primaryColor', 'primaryColorHex');
        bindColorPair('textColor', 'textColorHex');
        bindColorPair('accentColor', 'accentColorHex');
        bindColorPair('tileColor', 'tileColorHex');

        var tileOpacityInput = document.getElementById('tileOpacity');
        var tileOpacityValue = document.getElementById('tileOpacityValue');
        if (tileOpacityInput && tileOpacityValue) {
            tileOpacityInput.addEventListener('input', function () {
                tileOpacityValue.textContent = tileOpacityInput.value + '%';
                schedulePreview();
            });
        }

        document.querySelectorAll('.font-scale-input').forEach(function (input) {
            input.addEventListener('input', function () {
                var output = document.querySelector('.font-scale-value[data-for="' + input.id + '"]');
                if (output) {
                    output.textContent = input.value + '%';
                }
                schedulePreview();
            });
        });

        var toggle = document.getElementById('colorModeToggle');
        var hidden = document.getElementById('colorModeInput');
        var label = document.getElementById('colorModeToggleLabel');
        var field = document.querySelector('.color-mode-field');
        var body = document.body;

        if (toggle && hidden && label && field) {
            var lightLabel = field.dataset.lightLabel || 'Light';
            var darkLabel = field.dataset.darkLabel || 'Dark';

            function applyAdminTheme(isLight) {
                body.classList.remove('admin-theme-light', 'admin-theme-dark');
                body.classList.add(isLight ? 'admin-theme-light' : 'admin-theme-dark');
                hidden.value = isLight ? 'light' : 'dark';
                label.textContent = isLight ? lightLabel : darkLabel;
            }

            toggle.addEventListener('change', function () {
                applyAdminTheme(toggle.checked);
                savePersonalPreferences(false);
            });
            applyAdminTheme(toggle.checked);
        }

        var adminLanguageSelect = document.getElementById('adminLanguage');
        if (adminLanguageSelect) {
            adminLanguageSelect.addEventListener('change', function () {
                if (window.AdminLocale) {
                    window.AdminLocale.apply(adminLanguageSelect.value);
                }
                savePersonalPreferences(true);
            });
        }

        ['titleRu', 'titleEn', 'titleHe'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) {
                el.addEventListener('input', schedulePreview);
            }
        });

        var languageSelect = document.getElementById('language');
        if (languageSelect) {
            languageSelect.addEventListener('change', schedulePreview);
        }

        var candlePaletteSelect = document.getElementById('candlePalette');
        if (candlePaletteSelect) {
            candlePaletteSelect.addEventListener('change', schedulePreview);
        }

        var logoBorderRadiusInput = document.getElementById('logoBorderRadius');
        if (logoBorderRadiusInput) {
            logoBorderRadiusInput.addEventListener('input', schedulePreview);
        }

        var activeSavedViewId = '{{activeSavedViewId}}' || '';
        var updateCurrentViewBtn = document.getElementById('updateCurrentViewBtn');
        var savedViewsGrid = document.getElementById('savedViewsGrid');

        function setActiveSavedView(viewId, viewName) {
            activeSavedViewId = viewId || '';
            document.querySelectorAll('.saved-view-card').forEach(function (card) {
                card.classList.toggle('is-active', card.dataset.viewId === activeSavedViewId);
            });
            if (updateCurrentViewBtn) {
                updateCurrentViewBtn.disabled = !activeSavedViewId;
            }
            if (window.AdminSettingsPanel && typeof window.AdminSettingsPanel.updateActiveViewBadge === 'function') {
                window.AdminSettingsPanel.updateActiveViewBadge(viewName || '');
            }
        }

        function captureScreenshotDataUrl() {
            if (window.AdminSettingsPanel && typeof window.AdminSettingsPanel.capturePreviewScreenshot === 'function') {
                return window.AdminSettingsPanel.capturePreviewScreenshot();
            }
            return Promise.resolve('');
        }

        [
            ['memorialQrTitleScale', 'memorialQrTitleScaleValue'],
            ['memorialQrTextScale', 'memorialQrTextScaleValue'],
            ['memorialQrQrScale', 'memorialQrQrScaleValue'],
        ].forEach(function (pair) {
            var input = document.getElementById(pair[0]);
            var output = document.getElementById(pair[1]);
            if (!input || !output) {
                return;
            }
            input.addEventListener('input', function () {
                output.textContent = input.value + '%';
                schedulePreview();
            });
        });

        document.querySelectorAll('.memorial-qr-preview-input').forEach(function (input) {
            input.addEventListener('input', schedulePreview);
            input.addEventListener('change', schedulePreview);
        });

        var resetBtn = document.getElementById('resetThemeBtn');
        var resetForm = document.getElementById('resetThemeForm');
        if (resetBtn && resetForm) {
            resetBtn.addEventListener('click', function () {
                if (confirm('{{t 'reset_theme_confirm'}}')) {
                    resetForm.submit();
                }
            });
        }

        function schedulePreview() {
            clearTimeout(previewDebounce);
            previewDebounce = setTimeout(updatePreview, 120);
        }

        function postPreviewToFrame(frame) {
            if (!frame || !frame.contentWindow) {
                return;
            }

            try {
                frame.contentWindow.postMessage(readPreviewPatch(), window.location.origin);
            } catch (err) {
                /* iframe may still be loading */
            }
        }

        function buildPreviewSearchParams(patch) {
            var params = new URLSearchParams();
            params.set('preview', '1');
            params.set('titleRu', patch.titleRu || '');
            params.set('titleEn', patch.titleEn || '');
            params.set('titleHe', patch.titleHe || '');
            params.set('primaryColor', patch.primaryColor || '');
            params.set('textColor', patch.textColor || '');
            params.set('accentColor', patch.accentColor || '');
            params.set('tileColor', patch.tileColor || '');
            params.set('tileOpacity', patch.tileOpacity || '100');
            if (patch.candlePalette) {
                params.set('candlePalette', patch.candlePalette);
            }
            if (patch.logoBorderRadius !== undefined && patch.logoBorderRadius !== '') {
                params.set('logoBorderRadius', patch.logoBorderRadius);
            }
            Object.keys(patch).forEach(function (key) {
                if (key.indexOf('fontScale_') === 0 || key.indexOf('memorialQr') === 0) {
                    params.set(key, patch[key]);
                }
            });
            if (patch.previewLang) {
                params.set('previewLang', patch.previewLang);
            }
            return params;
        }

        function reloadBoardPreviewFromServer() {
            var frame = document.getElementById('boardPreviewFrame');
            if (!frame) {
                return;
            }

            frame.dataset.previewReady = '0';
            frame.src = '/s/' + slug + '?' + buildPreviewSearchParams(readPreviewPatch()).toString();
        }

        function updatePreview() {
            var frame = document.getElementById('boardPreviewFrame');
            if (!frame) return;

            postPreviewToFrame(frame);

            if (frame.dataset.previewReady === '1') {
                return;
            }

            frame.src = '/s/' + slug + '?' + buildPreviewSearchParams(readPreviewPatch()).toString();
        }

        var frame = document.getElementById('boardPreviewFrame');
        if (frame) {
            frame.addEventListener('load', function () {
                frame.dataset.previewReady = '1';
                postPreviewToFrame(frame);
                fitBoardPreviewTv();
            });

            frame.src = '/s/' + slug + '?' + buildPreviewSearchParams(readPreviewPatch()).toString();
            fitBoardPreviewTv();
        }

        var settingsForm = document.getElementById('settingsForm');
        if (settingsForm) {
            settingsForm.querySelectorAll('input[type="file"]').forEach(function (input) {
                input.addEventListener('change', function () {
                    var card = input.closest('.media-upload-card');
                    var hint = card && card.querySelector('.file-selected-hint');
                    if (!hint) {
                        hint = document.createElement('p');
                        hint.className = 'field-hint file-selected-hint';
                        card.appendChild(hint);
                    }
                    hint.textContent = input.files && input.files[0]
                        ? input.files[0].name + ' — ' + (settingsForm.dataset.saveLabel || '')
                        : '';
                });
            });

            settingsForm.addEventListener('submit', function () {
                var overlay = document.getElementById('adminBusyOverlay');
                var busyText = document.getElementById('adminBusyText');
                if (overlay) {
                    overlay.hidden = false;
                    overlay.setAttribute('aria-hidden', 'false');
                    document.body.classList.add('admin-is-busy');
                }
                if (busyText) {
                    busyText.textContent = '{{t 'saving'}}';
                }
            });
        }

        function resetTypographySlidersToBaseline() {
            document.querySelectorAll('input[name^="fontScale_"]').forEach(function (input) {
                input.value = 100;
                var output = document.querySelector('.font-scale-value[data-for="' + input.name + '"]');
                if (output) {
                    output.textContent = '100%';
                }
            });

            ['memorialQrTitleScale', 'memorialQrTextScale', 'memorialQrQrScale'].forEach(function (id) {
                var input = document.getElementById(id);
                if (!input) {
                    return;
                }
                input.value = 100;
                var output = document.getElementById(id + 'Value');
                if (output) {
                    output.textContent = '100%';
                }
            });

            schedulePreview();
        }

        function readBoardFeaturesPatch() {
            var patch = {};
            document.querySelectorAll('input[id^="feature_"]').forEach(function (input) {
                patch[input.id] = input.checked ? '1' : '';
            });
            return patch;
        }

        function readFeatureSettingsPatch() {
            var shabbat = document.getElementById('shabbatTimesEnabled');
            var publicSubmission = document.getElementById('publicSubmissionEnabled');
            var donationUrl = document.getElementById('publicSubmissionDonationUrl');
            return {
                shabbatTimesEnabled: shabbat && shabbat.checked ? '1' : '',
                publicSubmissionEnabled: publicSubmission && publicSubmission.checked ? '1' : '',
                publicSubmissionDonationUrl: donationUrl ? donationUrl.value.trim() : '',
            };
        }

        function readCurrentDesignPatch() {
            var patch = readPreviewPatch();
            var languageSelect = document.getElementById('language');
            var payload = Object.assign({}, patch, readBoardFeaturesPatch(), readFeatureSettingsPatch(), {
                name: '',
                language: languageSelect ? languageSelect.value : 'ru',
            });
            delete payload.type;
            delete payload.previewLang;
            return payload;
        }

        function formatSavedAt(value) {
            try {
                return new Date(value).toLocaleString();
            } catch (err) {
                return value || '';
            }
        }

        function renderSavedViewCard(view) {
            var article = document.createElement('article');
            article.className = 'saved-view-card' + (view.id === activeSavedViewId ? ' is-active' : '');
            article.dataset.viewId = view.id;

            var thumb = document.createElement('div');
            thumb.className = 'saved-view-thumb';
            if (view.screenshot) {
                var img = document.createElement('img');
                img.src = '/images/' + view.screenshot;
                img.alt = view.name || '';
                thumb.appendChild(img);
            } else {
                var empty = document.createElement('div');
                empty.className = 'saved-view-thumb-empty';
                empty.textContent = '{{t 'no_photo'}}';
                thumb.appendChild(empty);
            }
            var thumbLabel = document.createElement('span');
            thumbLabel.className = 'saved-view-thumb-label';
            thumbLabel.textContent = view.name || '';
            thumb.appendChild(thumbLabel);

            var meta = document.createElement('div');
            meta.className = 'saved-view-meta';
            var title = document.createElement('h3');
            title.textContent = view.name || '';
            var time = document.createElement('time');
            time.dateTime = view.savedAt || '';
            time.textContent = formatSavedAt(view.savedAt);
            meta.appendChild(title);
            meta.appendChild(time);

            var actions = document.createElement('div');
            actions.className = 'saved-view-card-actions';
            var applyBtn = document.createElement('button');
            applyBtn.type = 'button';
            applyBtn.className = 'btn-admin btn-admin-secondary saved-view-apply-btn btn-admin-with-icon';
            applyBtn.innerHTML = (window.AdminIcons ? window.AdminIcons.render('apply', 'btn-admin-icon') : '') + ' {{t 'saved_view_apply'}}';
            var deleteBtn = document.createElement('button');
            deleteBtn.type = 'button';
            deleteBtn.className = 'btn-admin btn-admin-danger saved-view-delete-btn btn-admin-with-icon';
            deleteBtn.innerHTML = (window.AdminIcons ? window.AdminIcons.render('delete', 'btn-admin-icon') : '') + ' {{t 'saved_view_delete'}}';
            actions.appendChild(applyBtn);
            actions.appendChild(deleteBtn);

            article.appendChild(thumb);
            article.appendChild(meta);
            article.appendChild(actions);
            return article;
        }

        function prependSavedView(view) {
            var grid = document.getElementById('savedViewsGrid');
            if (!grid) {
                return;
            }

            var empty = document.getElementById('savedViewsEmpty');
            if (empty) {
                empty.remove();
            }

            grid.insertBefore(renderSavedViewCard(view), grid.firstChild);
        }

        var saveCurrentViewBtn = document.getElementById('saveCurrentViewBtn');
        if (saveCurrentViewBtn) {
            saveCurrentViewBtn.addEventListener('click', function () {
                var name = window.prompt('{{t 'saved_view_name_prompt'}}');
                if (!name || !name.trim()) {
                    return;
                }

                saveCurrentViewBtn.disabled = true;
                var originalText = saveCurrentViewBtn.textContent;
                saveCurrentViewBtn.textContent = '{{t 'saving_view'}}';

                captureScreenshotDataUrl().then(function (screenshotDataUrl) {
                    var payload = readCurrentDesignPatch();
                    payload.name = name.trim();
                    if (screenshotDataUrl) {
                        payload.screenshotDataUrl = screenshotDataUrl;
                    }

                    return fetch('/admin/' + slug + '/settings/saved-views', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest',
                        },
                        body: JSON.stringify(payload),
                    });
                }).then(function (response) {
                    return response.json();
                }).then(function (data) {
                    if (data && data.ok && data.view) {
                        prependSavedView(data.view);
                        if (data.resetTypography) {
                            resetTypographySlidersToBaseline();
                        }
                        reloadBoardPreviewFromServer();
                        window.alert('{{t 'saved_view_saved'}}');
                    }
                }).catch(function () {
                    /* ignore */
                }).finally(function () {
                    saveCurrentViewBtn.disabled = false;
                    saveCurrentViewBtn.textContent = originalText;
                });
            });
        }

        if (updateCurrentViewBtn) {
            updateCurrentViewBtn.addEventListener('click', function () {
                if (!activeSavedViewId) {
                    window.alert('{{t 'update_current_view_missing'}}');
                    return;
                }

                updateCurrentViewBtn.disabled = true;
                var originalText = updateCurrentViewBtn.textContent;
                updateCurrentViewBtn.textContent = '{{t 'saving_view'}}';

                captureScreenshotDataUrl().then(function (screenshotDataUrl) {
                    var payload = readCurrentDesignPatch();
                    if (screenshotDataUrl) {
                        payload.screenshotDataUrl = screenshotDataUrl;
                    }

                    return fetch('/admin/' + slug + '/settings/saved-views/' + encodeURIComponent(activeSavedViewId), {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest',
                        },
                        body: JSON.stringify(payload),
                    });
                }).then(function (response) {
                    return response.json();
                }).then(function (data) {
                    if (data && data.ok && data.view) {
                        var existing = savedViewsGridEl && savedViewsGridEl.querySelector('[data-view-id="' + activeSavedViewId + '"]');
                        var replacement = renderSavedViewCard(data.view);
                        if (existing) {
                            existing.replaceWith(replacement);
                        }
                        if (data.resetTypography) {
                            resetTypographySlidersToBaseline();
                        }
                        reloadBoardPreviewFromServer();
                        window.alert('{{t 'update_current_view_saved'}}');
                    }
                }).catch(function () {
                    /* ignore */
                }).finally(function () {
                    updateCurrentViewBtn.disabled = !activeSavedViewId;
                    updateCurrentViewBtn.textContent = originalText;
                });
            });
        }

        if (savedViewsGrid && window.AdminSettingsPanel && typeof window.AdminSettingsPanel.initSavedViewsGrid === 'function') {
            window.AdminSettingsPanel.initSavedViewsGrid({
                slug: slug,
                deleteConfirm: savedViewsGrid.dataset.deleteConfirm,
                emptyText: savedViewsGrid.dataset.emptyText,
                applyError: savedViewsGrid.dataset.applyError,
                deleteError: savedViewsGrid.dataset.deleteError,
                onApply: function (viewId, viewName) {
                    setActiveSavedView(viewId, viewName);
                },
                onDelete: function (viewId) {
                    if (viewId === activeSavedViewId) {
                        setActiveSavedView('', '');
                    }
                },
                onSnapshotApplied: function () {
                    reloadBoardPreviewFromServer();
                },
            });
        }

    })();
</script>
