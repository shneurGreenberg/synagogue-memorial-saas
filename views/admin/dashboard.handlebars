<div class="admin-page settings-page">
    <header class="admin-page-header">
        <div>
            <h1>{{t 'settings'}}</h1>
            <p class="admin-subtitle">{{t 'settings_subtitle'}}</p>
        </div>
    </header>

  {{#if saved}}
    <div class="alert alert-success alert-dismissible fade show admin-alert" role="alert">
        {{t 'saved_settings'}}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
  {{/if}}

    <form method="POST" action="/admin/{{synagogue.slug}}/settings" enctype="multipart/form-data" class="settings-form">
        <section class="admin-panel">
            <div class="admin-panel-header">
                <h2>{{t 'appearance_section'}}</h2>
            </div>
            <div class="admin-panel-body">
                <div class="form-field">
                    <label for="settingsTitle">{{t 'title'}}</label>
                    <input type="text" name="title" id="settingsTitle" class="form-control"
                        value="{{synagogue.title}}">
                </div>
                <div class="form-field color-mode-field"
                    data-light-label="{{t 'light_mode'}}"
                    data-dark-label="{{t 'dark_mode'}}">
                    <span class="field-label-static">{{t 'color_mode'}}</span>
                    <input type="hidden" name="colorMode" id="colorModeInput"
                        value="{{#if (eq synagogue.theme.colorMode 'light')}}light{{else}}dark{{/if}}">
                    <label class="toggle-switch color-mode-toggle" for="colorModeToggle">
                        <input type="checkbox" id="colorModeToggle"
                            {{#if (eq synagogue.theme.colorMode 'light')}}checked{{/if}}>
                        <span class="toggle-slider"></span>
                        <span class="toggle-label" id="colorModeToggleLabel">
                            {{#if (eq synagogue.theme.colorMode 'light')}}{{t 'light_mode'}}{{else}}{{t 'dark_mode'}}{{/if}}
                        </span>
                    </label>
                    <span class="field-hint">{{t 'color_mode_help'}}</span>
                </div>
                <div class="color-picker-row">
                    <div class="form-field">
                        <label for="primaryColor">{{t 'primary_color'}}</label>
                        <div class="color-input-wrap">
                            <input type="color" name="primaryColor" id="primaryColor"
                                value="{{synagogue.theme.primaryColor}}">
                            <span class="color-value">{{synagogue.theme.primaryColor}}</span>
                        </div>
                    </div>
                    <div class="form-field">
                        <label for="textColor">{{t 'text_color'}}</label>
                        <div class="color-input-wrap">
                            <input type="color" name="textColor" id="textColor"
                                value="{{synagogue.theme.textColor}}">
                            <span class="color-value">{{synagogue.theme.textColor}}</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="admin-panel">
            <div class="admin-panel-header">
                <h2>{{t 'branding_section'}}</h2>
            </div>
            <div class="admin-panel-body media-upload-grid">
                <div class="media-upload-card">
                    <label>{{t 'logo'}}</label>
                    <div class="media-preview media-preview-logo">
                        {{#if synagogue.theme.logo}}
                        <img src="/images/{{synagogue.theme.logo}}" alt="{{t 'logo'}}">
                        {{else}}
                        <span class="media-preview-empty">{{t 'no_photo'}}</span>
                        {{/if}}
                    </div>
                    <label class="file-drop-label">
                        {{t 'replace_image'}}
                        <input type="file" name="logo" accept="image/*">
                    </label>
                </div>
                <div class="media-upload-card">
                    <label>{{t 'background_image'}}</label>
                    <div class="media-preview">
                        {{#if synagogue.theme.backgroundImage}}
                        <img src="/images/{{synagogue.theme.backgroundImage}}" alt="{{t 'background_image'}}">
                        {{else}}
                        <span class="media-preview-empty">{{t 'no_photo'}}</span>
                        {{/if}}
                    </div>
                    <label class="file-drop-label">
                        {{t 'replace_image'}}
                        <input type="file" name="backgroundImage" accept="image/*">
                    </label>
                </div>
                <div class="media-upload-card">
                    <label>{{t 'tiles_background'}}</label>
                    <div class="media-preview">
                        {{#if synagogue.theme.tilesBackground}}
                        <img src="/images/{{synagogue.theme.tilesBackground}}" alt="{{t 'tiles_background'}}">
                        {{else}}
                        <span class="media-preview-empty">{{t 'no_photo'}}</span>
                        {{/if}}
                    </div>
                    <label class="file-drop-label">
                        {{t 'replace_image'}}
                        <input type="file" name="tilesBackground" accept="image/*">
                    </label>
                </div>
            </div>
        </section>

        <section class="admin-panel">
            <div class="admin-panel-header">
                <h2>{{t 'languages_section'}}</h2>
            </div>
            <div class="admin-panel-body">
                <div class="settings-two-col">
                    <div class="form-field">
                        <label for="language">{{t 'language'}}</label>
                        <select name="language" id="language" class="form-control">
                            <option value="ru" {{#if (eq synagogue.language 'ru')}}selected{{/if}}>Russian</option>
                            <option value="en" {{#if (eq synagogue.language 'en')}}selected{{/if}}>English</option>
                            <option value="he" {{#if (eq synagogue.language 'he')}}selected{{/if}}>Hebrew</option>
                        </select>
                    </div>
                    <div class="form-field">
                        <label for="adminLanguage">{{t 'admin_language'}}</label>
                        <select name="adminLanguage" id="adminLanguage" class="form-control">
                            <option value="ru" {{#if (eq synagogue.adminLanguage 'ru')}}selected{{/if}}>Russian</option>
                            <option value="en" {{#if (eq synagogue.adminLanguage 'en')}}selected{{/if}}>English</option>
                            <option value="he" {{#if (eq synagogue.adminLanguage 'he')}}selected{{/if}}>Hebrew</option>
                        </select>
                    </div>
                </div>
            </div>
        </section>

        <div class="form-actions-sticky">
            <button type="submit" class="btn-admin btn-admin-primary">{{t 'save'}}</button>
        </div>
    </form>
</div>

<script>
    document.querySelectorAll('input[type="color"]').forEach(function (input) {
        const valueEl = input.parentElement.querySelector('.color-value');
        if (!valueEl) return;
        input.addEventListener('input', function () {
            valueEl.textContent = input.value;
        });
    });

    (function () {
        var toggle = document.getElementById('colorModeToggle');
        var hidden = document.getElementById('colorModeInput');
        var label = document.getElementById('colorModeToggleLabel');
        var field = document.querySelector('.color-mode-field');
        if (!toggle || !hidden || !label || !field) return;

        var lightLabel = field.dataset.lightLabel || 'Light';
        var darkLabel = field.dataset.darkLabel || 'Dark';

        function syncColorMode() {
            var isLight = toggle.checked;
            hidden.value = isLight ? 'light' : 'dark';
            label.textContent = isLight ? lightLabel : darkLabel;
        }

        toggle.addEventListener('change', syncColorMode);
        syncColorMode();
    })();
</script>
