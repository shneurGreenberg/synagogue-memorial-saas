<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="dark">
    <title>Admin Login</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin.css">
</head>

<body class="admin-login-page">
    <div class="admin-login-card">
        <div class="admin-login-header">
            <h1>Synagogue Admin</h1>
            <p>Sign in to manage your memorial board</p>
        </div>
        <div class="admin-login-body">
            {{#if error}}
            <div class="alert alert-danger mb-3">{{error}}</div>
            {{/if}}
            <form method="POST" action="/admin/login">
                <div class="form-group">
                    <label for="slug">Synagogue / User</label>
                    <input type="text" name="slug" id="slug" class="form-control" required autocomplete="username"
                        placeholder="novosibirsk or novosibirsk/yossi">
                    <small class="form-text text-muted">Enter synagogue slug only for full admin access, or slug/username for a specific staff member.</small>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" name="password" id="password" class="form-control" required
                        autocomplete="current-password">
                </div>
                <button type="submit" class="btn-admin btn-admin-primary">Login</button>
            </form>
        </div>
    </div>
</body>

</html>
