<div class="admin-page contacts-page" data-synagogue-slug="{{synagogue.slug}}" data-contact-directory-count="{{synagogue.contactDirectoryCount}}" data-contact-directory-count-label="{{t 'contact_directory_count'}}" data-manage-contacts-empty="{{t 'manage_contacts_empty'}}" data-manage-contacts-delete-confirm="{{t 'manage_contacts_delete_confirm'}}" data-manage-contacts-saved="{{t 'manage_contacts_saved'}}" data-manage-contacts-deleted="{{t 'manage_contacts_deleted'}}" data-edit-label="{{t 'edit'}}" data-add-contact-title="{{t 'manage_contacts_add'}}" data-edit-contact-title="{{t 'manage_contacts_edit'}}">
    <header class="admin-page-header">
        <div>
            <h1>{{t 'manage_contacts_title'}}</h1>
            <p class="admin-subtitle">{{t 'manage_contacts_subtitle'}}</p>
        </div>
        <div class="header-actions">
            <button type="button" class="btn-admin btn-admin-secondary btn-admin-with-icon" data-toggle="modal" data-target="#importContactsModal">
                {{{adminIcon 'import' class='btn-admin-inline-icon'}}}
                {{t 'import_contacts'}}
            </button>
            <button type="button" class="btn-admin btn-admin-primary btn-admin-with-icon" id="manageContactsAddBtn">
                {{{adminIcon 'add' class='btn-admin-inline-icon'}}}
                {{t 'manage_contacts_add_another'}}
            </button>
        </div>
    </header>

    {{#if contactsImported}}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{t 'import_contacts_done'}}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {{/if}}
    {{#if contactsImportError}}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{t 'import_contacts_error'}}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {{/if}}

    <div class="contacts-toolbar people-toolbar">
        <input type="search" id="manageContactsSearch" class="form-control admin-input" placeholder="{{t 'manage_contacts_search'}}" aria-label="{{t 'manage_contacts_search'}}">
        <span class="seed-notice contacts-directory-count" id="contactDirectoryCount"></span>
    </div>

    <div class="contacts-list" id="manageContactsList"></div>
    <p class="seed-notice manage-contacts-empty" id="manageContactsEmpty" hidden>{{t 'manage_contacts_empty'}}</p>
</div>

<!-- Add / Edit Contact Modal -->
<div class="modal fade admin-modal" id="manageContactModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="manageContactForm">
                <input type="hidden" id="manageContactId" value="">
                <div class="modal-header">
                    <h5 class="modal-title" id="manageContactModalTitle">{{t 'manage_contacts_add'}}</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-field">
                        <label for="manageContactName">{{t 'contact_name'}}</label>
                        <input type="text" id="manageContactName" class="form-control" maxlength="120" required>
                    </div>
                    <div class="form-field">
                        <label for="manageContactPhone">{{t 'contact_phone'}}</label>
                        <input type="tel" id="manageContactPhone" class="form-control" maxlength="30">
                    </div>
                    <div class="form-field">
                        <label for="manageContactEmail">{{t 'contact_email'}}</label>
                        <input type="email" id="manageContactEmail" class="form-control" maxlength="200">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn-admin btn-admin-primary btn-admin-with-icon" id="manageContactSaveBtn">{{{adminIcon 'save' class='btn-admin-inline-icon'}}}{{t 'manage_contacts_save'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Import Contacts Modal -->
<div class="modal fade admin-modal" id="importContactsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="importContactsForm" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title">{{t 'import_contacts'}}</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="{{t 'cancel'}}">&times;</button>
                </div>
                <div class="modal-body">
                    <p class="seed-notice">{{t 'import_contacts_help'}}</p>
                    <div class="form-field">
                        <label for="importContactsFile">CSV / vCard</label>
                        <input type="file" name="file" id="importContactsFile" class="form-control" accept=".csv,.vcf,.txt,text/csv,text/vcard" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn-admin btn-admin-primary btn-admin-with-icon" id="importContactsSubmit">{{{adminIcon 'import' class='btn-admin-inline-icon'}}}{{t 'import_contacts_submit'}}</button>
                </div>
            </form>
        </div>
    </div>
</div>
