<div class="admin-page slideshow-page">
    <header class="admin-page-header">
        <div>
            <h1>{{t 'slideshow'}}</h1>
            <p class="admin-subtitle">{{t 'slideshow_subtitle'}}</p>
        </div>
    </header>

    <section class="admin-panel">
        <div class="admin-panel-header">
            <h2>{{t 'slideshow_settings_section'}}</h2>
            <p class="admin-panel-desc">{{t 'slideshow_timing_help'}}</p>
        </div>
        <div class="admin-panel-body">
            <form method="POST" action="/admin/{{synagogue.slug}}/slideshow/settings" class="slideshow-settings-form">
                <label class="toggle-switch">
                    <input type="checkbox" name="enabled" {{#if synagogue.slideshow.enabled}}checked{{/if}}>
                    <span class="toggle-slider"></span>
                    <span class="toggle-label">{{t 'enable_slideshow'}}</span>
                </label>
                <div class="settings-two-col">
                    <div class="form-field">
                        <label for="slideInterval">{{t 'slide_duration'}}</label>
                        <input type="number" class="form-control" name="interval" id="slideInterval"
                            value="{{synagogue.slideshow.interval}}" min="3" required>
                    </div>
                    <div class="form-field">
                        <label for="mainDuration">{{t 'main_duration'}}</label>
                        <input type="number" class="form-control" name="mainDuration" id="mainDuration"
                            value="{{synagogue.slideshow.mainDuration}}" min="10" required>
                        <span class="field-hint">{{t 'main_duration_help'}}</span>
                    </div>
                </div>
                <button type="submit" class="btn-admin btn-admin-primary">{{t 'save'}}</button>
            </form>
        </div>
    </section>

    <section class="admin-panel">
        <div class="admin-panel-header">
            <h2>{{t 'add_new_slide'}}</h2>
        </div>
        <div class="admin-panel-body">
            <form method="POST" action="/admin/{{synagogue.slug}}/slideshow/add" enctype="multipart/form-data"
                class="add-slide-form">
                <div class="add-slide-layout">
                    <div class="media-upload-card add-slide-preview-card">
                        <div class="media-preview media-preview-slide" id="slidePreview">
                            <span class="media-preview-empty">{{t 'upload_photo'}}</span>
                        </div>
                        <label class="file-drop-label">
                            {{t 'image'}}
                            <input type="file" name="image" accept="image/*" required id="slideImageInput">
                        </label>
                    </div>
                    <div class="add-slide-fields">
                        <div class="form-field">
                            <label for="slideText">{{t 'slide_caption_optional'}}</label>
                            <input type="text" name="text" id="slideText" class="form-control"
                                placeholder="{{t 'text'}}">
                        </div>
                        <button type="submit" class="btn-admin btn-admin-primary">+ {{t 'add'}}</button>
                    </div>
                </div>
            </form>
        </div>
    </section>

    <section class="admin-panel">
        <div class="admin-panel-header">
            <h2>{{t 'current_slides'}}</h2>
        </div>
        <div class="admin-panel-body">
            <div class="slides-grid">
                {{#each synagogue.slideshow.images}}
                <article class="slide-card">
                    <div class="slide-card-image">
                        <img src="/images/{{this.url}}" alt="{{this.text}}">
                    </div>
                    <div class="slide-card-body">
                        {{#if this.text}}
                        <p class="slide-caption">{{this.text}}</p>
                        {{else}}
                        <p class="slide-caption slide-caption-muted">{{t 'slide_caption_optional'}}</p>
                        {{/if}}
                        <form method="POST" action="/admin/{{../synagogue.slug}}/slideshow/delete"
                            onsubmit="return confirm('{{t 'are_you_sure'}}');">
                            <input type="hidden" name="slideId" value="{{this._id}}">
                            <button type="submit" class="btn-admin btn-admin-danger btn-admin-sm">{{t 'delete'}}</button>
                        </form>
                    </div>
                </article>
                {{else}}
                <div class="admin-empty-state slides-grid-empty">
                    <p>{{t 'no_slides'}}</p>
                </div>
                {{/each}}
            </div>
        </div>
    </section>
</div>

<script>
    (function () {
        const input = document.getElementById('slideImageInput');
        const preview = document.getElementById('slidePreview');
        if (!input || !preview) return;

        input.addEventListener('change', function () {
            const file = input.files && input.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function (e) {
                preview.innerHTML = '<img src="' + e.target.result + '" alt="">';
            };
            reader.readAsDataURL(file);
        });
    })();
</script>
