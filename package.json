  "scripts": {
    "start": "node app.js",
    "start:prod": "(node scripts/seed.js || true) && node scripts/prebuild-css.js && exec node app.js",
    "restart": "yarn stop && pm2 start app.js && pm2 logs",
    "stop": "pm2 kill",
    "seed": "node scripts/seed.js",
    "yahrzeit-reminders": "node scripts/send-yahrzeit-reminders.js",
    "seed:hayom-yom": "node scripts/seed-hayom-yom.js",
    "seed:photos": "node scripts/seed-photos.js --slug=novosibirsk --force",
    "build:board": "node scripts/bump-board-version.js && vite build --config vite.board.config.mjs",
    "prebuild:css": "node scripts/prebuild-css.js",
    "build:css": "node scripts/prebuild-css.js",
    "build:pages": "node scripts/build-github-pages.js",
    "dev:board": "vite build --config vite.board.config.mjs --watch"
  },
  "dependencies": {
    "@babel/core": "^7.13.10",
    "@babel/preset-env": "^7.13.10",
    "@babel/preset-react": "^7.12.13",
