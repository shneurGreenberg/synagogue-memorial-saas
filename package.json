    "bcryptjs": "^3.0.3",
    "body-parser": "^1.19.0",
    "compression": "^1.8.1",
    "connect-mongo": "^4.0.0",
    "cookie-parser": "^1.4.0",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "express-browserify": "^1.0.3",
    "express-handlebars": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.17.0",
    "geo-tz": "^8.1.7",
    "hebcal": "^2.3.2",
    "helmet": "^8.3.0",
    "i18next": "^20.0.0",
    "mongoose": "^6.0.0",
    "multer": "^2.0.2",
    "nodemailer": "^9.0.1",
    "passport": "^0.4.0",
    "passport-local": "^1.0.0",
    "pm2": "^4.5.5",
    "prop-types": "^15.7.2",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-i18next": "^11.0.0",
    "react-live-clock": "^5.0.16",
    "react-moment": "^1.1.1",
    "react-router-dom": "^6.30.3",
    "rimraf": "^3.0.2",
    "sanitize-html": "^2.17.4",
